---
import ContentLayout from "@/layouts/ContentLayout.astro";
---
<ContentLayout title="Forgot Password — Verscienta Health" description="Reset your Verscienta Health account password.">
  <div class="min-h-[60vh] flex items-center justify-center py-16">
    <div class="w-full max-w-md px-4">
      <div class="text-center mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-earth-100 mb-2">Forgot Password</h1>
        <p class="text-gray-600 dark:text-earth-300">Enter your email and we'll send you a reset link.</p>
      </div>
      <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 shadow-sm">
        <form class="space-y-4">
          <div>
            <label for="email" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Email Address</label>
            <input type="email" id="email" name="email" required autocomplete="email" class="w-full px-4 py-2.5 border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" />
          </div>
          <button type="submit" class="w-full px-6 py-3 bg-gradient-to-r from-sage-600 to-earth-600 text-white font-medium rounded-xl shadow hover:shadow-lg transition-all">Send Reset Link</button>
        </form>
        <p class="mt-4 text-center text-sm text-gray-600 dark:text-earth-400">
          Remember your password? <a href="/login" class="text-sage-600 dark:text-sage-400 hover:underline">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</ContentLayout>
