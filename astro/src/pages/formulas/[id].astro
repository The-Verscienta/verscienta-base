---
import ContentLayout from "@/layouts/ContentLayout.astro";
import { directus, readItems, readItem } from "@/lib/directus";

const { id } = Astro.params;
let formula: any = null;
try {
  const bySlug = await directus.request(readItems("formulas", {
    filter: { slug: { _eq: id } },
    fields: ["*",
      "ingredients.*", "ingredients.herb_id.id", "ingredients.herb_id.title", "ingredients.herb_id.slug",
      "modifications.*", "modifications.herb_id.id", "modifications.herb_id.title",
      "conditions.conditions_id.id", "conditions.conditions_id.title", "conditions.conditions_id.slug",
      "related_formulas.related_formulas_id.id", "related_formulas.related_formulas_id.title", "related_formulas.related_formulas_id.slug",
    ],
    limit: 1,
  }));
  formula = bySlug?.[0] || null;
  if (!formula && /^\d+$/.test(id!)) {
    formula = await directus.request(readItem("formulas", parseInt(id!), {
      fields: ["*", "ingredients.*", "ingredients.herb_id.*", "modifications.*", "modifications.herb_id.*", "conditions.conditions_id.*"],
    }));
  }
} catch (e) { console.error("Error:", e); }
if (!formula) return Astro.redirect("/404");

const roleLabels: Record<string, string> = { chief: "Jun (Chief)", deputy: "Chen (Deputy)", assistant: "Zuo (Assistant)", envoy: "Shi (Envoy)" };
const roleColors: Record<string, string> = { chief: "bg-amber-100 text-amber-700 border-amber-200", deputy: "bg-blue-100 text-blue-700 border-blue-200", assistant: "bg-green-100 text-green-700 border-green-200", envoy: "bg-purple-100 text-purple-700 border-purple-200" };
---

<ContentLayout title={`${formula.title} — Verscienta Health`} description={`Traditional herbal formula: ${formula.title}. Ingredients, modifications, and clinical notes.`}>
  <section class="bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <nav class="text-sm text-gray-500 dark:text-earth-400 mb-4"><a href="/" class="hover:text-sage-600">Home</a> / <a href="/formulas" class="hover:text-sage-600">Formulas</a> / <span class="text-gray-900 dark:text-earth-100">{formula.title}</span></nav>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 dark:text-earth-100 mb-2">{formula.title}</h1>
      {formula.chinese_name && <p class="text-xl font-chinese text-sage-600 dark:text-sage-400">{formula.chinese_name} {formula.pinyin_name && `(${formula.pinyin_name})`}</p>}
      {formula.classic_source && <p class="text-sm text-gray-500 dark:text-earth-400 mt-2">Source: {formula.classic_source} {formula.source_author && `— ${formula.source_author}`} {formula.source_dynasty && `(${formula.source_dynasty})`}</p>}
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-12">
    {formula.description && <section><h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Description</h2><div class="prose prose-earth dark:prose-invert max-w-none" set:html={formula.description} /></section>}

    {/* Ingredients table */}
    {formula.ingredients?.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Composition</h2>
        <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 overflow-hidden">
          <table class="w-full text-sm">
            <thead><tr class="bg-sage-50 dark:bg-earth-800 border-b border-gray-200 dark:border-earth-700">
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Herb</th>
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Amount</th>
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Role</th>
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Function</th>
            </tr></thead>
            <tbody>
              {formula.ingredients.sort((a: any, b: any) => { const order = ["chief","deputy","assistant","envoy"]; return (order.indexOf(a.role)||99) - (order.indexOf(b.role)||99); }).map((ing: any) => (
                <tr class="border-b border-gray-100 dark:border-earth-800">
                  <td class="px-4 py-3"><a href={`/herbs/${ing.herb_id?.slug || ing.herb_id?.id}`} class="text-sage-600 dark:text-sage-400 hover:underline font-medium">{ing.herb_id?.title || "Herb"}</a></td>
                  <td class="px-4 py-3 text-gray-600 dark:text-earth-300">{ing.quantity}{ing.unit} {ing.percentage ? `(${ing.percentage}%)` : ""}</td>
                  <td class="px-4 py-3">{ing.role && <span class={`text-xs px-2 py-0.5 rounded-full border ${roleColors[ing.role] || "bg-gray-100 text-gray-700"}`}>{roleLabels[ing.role] || ing.role}</span>}</td>
                  <td class="px-4 py-3 text-gray-600 dark:text-earth-300">{ing.function || "—"}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
        {formula.total_weight && <p class="text-sm text-gray-500 dark:text-earth-400 mt-2">Total weight: {formula.total_weight}{formula.total_weight_unit || "g"}</p>}
      </section>
    )}

    {/* Jia-Jian Modifications */}
    {formula.modifications?.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">加减 Modifications (Jiā Jiǎn)</h2>
        <div class="space-y-3">
          {formula.modifications.map((mod: any) => (
            <div class="bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${mod.action === "add" ? "bg-green-100 text-green-700" : mod.action === "remove" ? "bg-red-100 text-red-700" : "bg-amber-100 text-amber-700"}`}>{mod.action}</span>
                <a href={`/herbs/${mod.herb_id?.id}`} class="font-medium text-sage-600 hover:underline">{mod.herb_id?.title || "Herb"}</a>
                {mod.amount && <span class="text-sm text-gray-500">({mod.amount})</span>}
              </div>
              <p class="text-sm text-gray-600 dark:text-earth-300"><span class="font-medium">When:</span> {mod.condition}</p>
              {mod.note && <p class="text-sm text-gray-500 dark:text-earth-400 mt-1">{mod.note}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    {formula.preparation_instructions && <section><h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Preparation</h2><div class="prose prose-earth dark:prose-invert max-w-none" set:html={formula.preparation_instructions} /></section>}
    {formula.dosage && <section><h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Dosage</h2><div class="prose prose-earth dark:prose-invert max-w-none" set:html={formula.dosage} /></section>}

    {/* Conditions */}
    {formula.conditions?.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Conditions Addressed</h2>
        <div class="flex flex-wrap gap-2">
          {formula.conditions.map((c: any) => (
            <a href={`/conditions/${c.conditions_id?.slug || c.conditions_id?.id}`} class="px-3 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm hover:bg-blue-200 transition">{c.conditions_id?.title}</a>
          ))}
        </div>
      </section>
    )}

    <!-- TODO Phase 6: Add <SimilarFormulas client:visible />, <FormulaNetwork client:visible />, <ExplainToPatientButton client:load /> React islands -->
  </div>
</ContentLayout>
