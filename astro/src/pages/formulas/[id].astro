---
import ContentLayout from "@/layouts/ContentLayout.astro";
import { directus, readItems, readItem } from "@/lib/directus";
import { imageUrl } from "@/lib/image-url";
import { fetchAllFormulasForSimilarity, computeSimilarFormulas } from "@/lib/formula-similarity";
import ExplainFormulaButton from "@/components/ExplainFormulaButton";

const { id } = Astro.params;

const FORMULA_FIELDS = [
  "*",
  "ingredients.*",
  "ingredients.herb_id.id", "ingredients.herb_id.title", "ingredients.herb_id.slug",
  "ingredients.herb_id.typical_dose_min", "ingredients.herb_id.typical_dose_max", "ingredients.herb_id.typical_dose_unit",
  "modifications.*", "modifications.herb_id.id", "modifications.herb_id.title", "modifications.herb_id.slug",
  "conditions.conditions_id.id", "conditions.conditions_id.title", "conditions.conditions_id.slug",
  "related_formulas.related_formulas_id.id", "related_formulas.related_formulas_id.title", "related_formulas.related_formulas_id.slug",
];

let formula: any = null;
try {
  const bySlug = await directus.request(readItems("formulas", {
    filter: { slug: { _eq: id } },
    fields: FORMULA_FIELDS,
    limit: 1,
  }));
  formula = bySlug?.[0] || null;
  if (!formula && /^\d+$/.test(id!)) {
    formula = await directus.request(readItem("formulas", parseInt(id!), { fields: FORMULA_FIELDS }));
  }
} catch (e) { console.error("Error:", e); }
if (!formula) return Astro.redirect("/404");

// Inline TCM clinical evidence + similar formulas (parallel)
let tcmEvidence: any[] = [];
let similarFormulas: any[] = [];
try {
  const [evidence, allFormulas] = await Promise.all([
    directus.request(readItems("tcm_clinical_evidence", {
      filter: { formula_id: { _eq: formula.id } },
      fields: ["id", "title", "evidence_id", "study_type", "summary", "outcome", "source_url", "source_db"],
      limit: 20,
    })).catch(() => []),
    fetchAllFormulasForSimilarity().catch(() => []),
  ]);
  tcmEvidence = evidence as any[];
  // Find this formula in the cached list (already has the same shape with ingredient herb_ids)
  const sourceForSim = allFormulas.find((f) => f.id === formula.id);
  if (sourceForSim) {
    similarFormulas = computeSimilarFormulas(sourceForSim, allFormulas, { minSimilarity: 30, maxResults: 8 });
  }
} catch (e) { console.error("Error fetching evidence / similar formulas:", e); }

const roleLabels: Record<string, string> = { chief: "Jun (Chief)", deputy: "Chen (Deputy)", assistant: "Zuo (Assistant)", envoy: "Shi (Envoy)" };
const roleColors: Record<string, string> = { chief: "bg-amber-100 text-amber-700 border-amber-200", deputy: "bg-blue-100 text-blue-700 border-blue-200", assistant: "bg-green-100 text-green-700 border-green-200", envoy: "bg-purple-100 text-purple-700 border-purple-200" };

// Trim trailing zeros, cap at 2 decimal places. "87.00000" → "87", "87.567" → "87.57"
const fmtNum = (v: any): string => {
  if (v == null || v === "") return "";
  const n = Number(v);
  return Number.isFinite(n) ? String(parseFloat(n.toFixed(2))) : String(v);
};

// Sum quantities per unit so we can compute percentage when not explicitly set.
// Falls back to ing.percentage if provided.
const unitTotals: Record<string, number> = {};
for (const ing of formula.ingredients || []) {
  const q = Number(ing?.quantity);
  if (ing?.unit && Number.isFinite(q)) {
    unitTotals[ing.unit] = (unitTotals[ing.unit] || 0) + q;
  }
}
const ingredientPct = (ing: any): number | null => {
  if (ing?.percentage != null && ing.percentage !== "") return Number(ing.percentage);
  const total = unitTotals[ing?.unit];
  const q = Number(ing?.quantity);
  if (!total || !Number.isFinite(q) || total === 0) return null;
  return (q / total) * 100;
};

// Strip HTML for the explain-formula description payload
const stripHtml = (html: string | null | undefined) =>
  html ? html.replace(/<[^>]*>/g, " ").replace(/\s+/g, " ").trim().slice(0, 1500) : undefined;

// Shape the formula for the ExplainFormulaButton React island
const explainHerbs = (formula.ingredients || [])
  .filter((ing: any) => ing?.herb_id?.title)
  .map((ing: any) => ({
    name: ing.herb_id.title,
    role: ing.role || undefined,
    amount: ing.quantity != null && ing.quantity !== "" ? `${fmtNum(ing.quantity)}${ing.unit || ""}` : undefined,
  }));
---

<ContentLayout title={`${formula.title} — Verscienta Health`} description={`Traditional herbal formula: ${formula.title}. Ingredients, modifications, and clinical notes.`}>
  <section class="bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <nav class="text-sm text-gray-500 dark:text-earth-400 mb-4"><a href="/" class="hover:text-sage-600">Home</a> / <a href="/formulas" class="hover:text-sage-600">Formulas</a> / <span class="text-gray-900 dark:text-earth-100">{formula.title}</span></nav>
      <div class="flex flex-col md:flex-row gap-8">
        <div class="flex-1">
          <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 dark:text-earth-100 mb-2">{formula.title}</h1>
          {formula.chinese_name && <p class="text-xl font-chinese text-sage-600 dark:text-sage-400">{formula.chinese_name} {formula.pinyin_name && `(${formula.pinyin_name})`}</p>}
          {formula.classic_source && (
            <p class="text-sm text-gray-500 dark:text-earth-400 mt-2">
              Source: {formula.classic_source}
              {formula.source_author && ` — ${formula.source_author}`}
              {(formula.source_dynasty || formula.source_year) && ` (${[formula.source_dynasty, formula.source_year].filter(Boolean).join(", ")})`}
            </p>
          )}
          {formula.use_cases?.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {formula.use_cases.map((u: string) => (
                <span class="text-xs px-3 py-1 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300">{u}</span>
              ))}
            </div>
          )}
          {explainHerbs.length > 0 && (
            <div class="mt-5">
              <ExplainFormulaButton
                client:load
                formulaName={formula.title}
                description={stripHtml(formula.description)}
                herbs={explainHerbs}
              />
            </div>
          )}
        </div>
        {formula.image && (
          <div class="w-full md:w-64 aspect-square rounded-xl overflow-hidden shadow-lg flex-shrink-0">
            <img
              src={imageUrl(formula.image, { width: 512, height: 512 })}
              alt={formula.title}
              class="w-full h-full object-cover"
            />
          </div>
        )}
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-12">
    {formula.description && <section><h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Description</h2><div class="prose prose-earth dark:prose-invert max-w-none" set:html={formula.description} /></section>}

    {/* Ingredients table */}
    {formula.ingredients?.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Composition</h2>
        <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 overflow-hidden">
          <table class="w-full text-sm">
            <thead><tr class="bg-sage-50 dark:bg-earth-800 border-b border-gray-200 dark:border-earth-700">
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Herb</th>
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Amount</th>
              <th class="text-right px-4 py-3 font-medium text-gray-500 dark:text-earth-400">%</th>
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Role</th>
              <th class="text-left px-4 py-3 font-medium text-gray-500 dark:text-earth-400">Function</th>
            </tr></thead>
            <tbody>
              {formula.ingredients.sort((a: any, b: any) => { const order = ["chief","deputy","assistant","envoy"]; return (order.indexOf(a.role)||99) - (order.indexOf(b.role)||99); }).map((ing: any) => {
                const pct = ingredientPct(ing);
                const h = ing.herb_id;
                const tMin = h?.typical_dose_min;
                const tMax = h?.typical_dose_max;
                const tUnit = h?.typical_dose_unit;
                const hasRange = (tMin != null && tMin !== "") || (tMax != null && tMax !== "");
                const rangeStr = hasRange
                  ? `${tMin != null && tMin !== "" ? fmtNum(tMin) : "?"}–${tMax != null && tMax !== "" ? fmtNum(tMax) : "?"}${tUnit || ""}`
                  : null;
                // Flag dose outside typical range when units match
                const q = Number(ing.quantity);
                const outOfRange = ing.unit && tUnit === ing.unit && Number.isFinite(q) && (
                  (tMin != null && tMin !== "" && q < Number(tMin)) ||
                  (tMax != null && tMax !== "" && q > Number(tMax))
                );
                return (
                <tr class="border-b border-gray-100 dark:border-earth-800 align-top">
                  <td class="px-4 py-3">
                    <a href={`/herbs/${ing.herb_id?.slug || ing.herb_id?.id}`} class="text-sage-600 dark:text-sage-400 hover:underline font-medium">{ing.herb_id?.title || "Herb"}</a>
                    {ing.notes && <div class="text-xs text-gray-500 dark:text-earth-400 mt-1 whitespace-pre-line">{ing.notes}</div>}
                  </td>
                  <td class="px-4 py-3 text-gray-600 dark:text-earth-300 whitespace-nowrap">
                    <span class={outOfRange ? "text-amber-700 dark:text-amber-400 font-medium" : ""} title={outOfRange ? "Outside typical dose range" : undefined}>
                      {fmtNum(ing.quantity)}{ing.unit}
                    </span>
                    {rangeStr && (
                      <div class="text-xs text-gray-400 dark:text-earth-500 mt-0.5 whitespace-nowrap">typical {rangeStr}</div>
                    )}
                  </td>
                  <td class="px-4 py-3 text-right text-gray-600 dark:text-earth-300 tabular-nums">{pct != null ? `${fmtNum(pct)}%` : "—"}</td>
                  <td class="px-4 py-3">{ing.role && <span class={`text-xs px-2 py-0.5 rounded-full border ${roleColors[ing.role] || "bg-gray-100 text-gray-700"}`}>{roleLabels[ing.role] || ing.role}</span>}</td>
                  <td class="px-4 py-3 text-gray-600 dark:text-earth-300">{ing.function || "—"}</td>
                </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        {formula.total_weight && <p class="text-sm text-gray-500 dark:text-earth-400 mt-2">Total weight: {fmtNum(formula.total_weight)}{formula.total_weight_unit || "g"}</p>}
      </section>
    )}

    {/* Jia-Jian Modifications */}
    {formula.modifications?.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">加减 Modifications (Jiā Jiǎn)</h2>
        <div class="space-y-3">
          {formula.modifications.map((mod: any) => (
            <div class="bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 p-4">
              <div class="flex items-center gap-2 mb-1">
                <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${mod.action === "add" ? "bg-green-100 text-green-700" : mod.action === "remove" ? "bg-red-100 text-red-700" : "bg-amber-100 text-amber-700"}`}>{mod.action}</span>
                <a href={`/herbs/${mod.herb_id?.slug || mod.herb_id?.id}`} class="font-medium text-sage-600 hover:underline">{mod.herb_id?.title || "Herb"}</a>
                {mod.amount && <span class="text-sm text-gray-500">({mod.amount})</span>}
              </div>
              <p class="text-sm text-gray-600 dark:text-earth-300"><span class="font-medium">When:</span> {mod.condition}</p>
              {mod.note && <p class="text-sm text-gray-500 dark:text-earth-400 mt-1">{mod.note}</p>}
            </div>
          ))}
        </div>
      </section>
    )}

    {formula.preparation_instructions && <section><h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Preparation</h2><div class="prose prose-earth dark:prose-invert max-w-none" set:html={formula.preparation_instructions} /></section>}
    {formula.dosage && <section><h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Dosage</h2><div class="prose prose-earth dark:prose-invert max-w-none" set:html={formula.dosage} /></section>}

    {/* Conditions */}
    {formula.conditions?.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Conditions Addressed</h2>
        <div class="flex flex-wrap gap-2">
          {formula.conditions.map((c: any) => (
            <a href={`/conditions/${c.conditions_id?.slug || c.conditions_id?.id}`} class="px-3 py-1.5 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 text-sm hover:bg-blue-200 transition">{c.conditions_id?.title}</a>
          ))}
        </div>
      </section>
    )}

    {/* Related formulas (M2M, manually curated) */}
    {formula.related_formulas?.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Related Formulas</h2>
        <div class="flex flex-wrap gap-2">
          {formula.related_formulas.map((rf: any) => (
            <a href={`/formulas/${rf.related_formulas_id?.slug || rf.related_formulas_id?.id}`} class="px-3 py-1.5 rounded-full bg-sage-100 dark:bg-sage-900/30 text-sage-700 dark:text-sage-300 text-sm hover:bg-sage-200 transition">
              {rf.related_formulas_id?.title}
            </a>
          ))}
        </div>
      </section>
    )}

    {/* Similar formulas (auto-computed by ingredient + dosage similarity) */}
    {similarFormulas.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">
          Similar Formulas
          <span class="text-sm font-normal text-gray-500 dark:text-earth-400 ml-2">
            by composition
          </span>
        </h2>
        <div class="grid sm:grid-cols-2 gap-3">
          {similarFormulas.map((sf: any) => (
            <a href={`/formulas/${sf.slug || sf.id}`} class="block bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 hover:border-sage-300 dark:hover:border-sage-700 hover:shadow-sm transition p-4">
              <div class="flex items-start justify-between gap-3">
                <div class="flex-1 min-w-0">
                  <div class="font-medium text-gray-900 dark:text-earth-100 hover:text-sage-600">{sf.title}</div>
                  {(sf.chinese_name || sf.pinyin_name) && (
                    <div class="text-xs text-gray-500 dark:text-earth-400 mt-0.5">{[sf.chinese_name, sf.pinyin_name].filter(Boolean).join(" · ")}</div>
                  )}
                  {sf.classic_source && (
                    <div class="text-xs text-gray-400 dark:text-earth-500 mt-0.5">{sf.classic_source}</div>
                  )}
                </div>
                <div class="flex flex-col items-end flex-shrink-0">
                  <span class={`text-sm font-bold tabular-nums ${sf.similarity >= 70 ? "text-green-700 dark:text-green-400" : sf.similarity >= 50 ? "text-sage-700 dark:text-sage-400" : "text-gray-600 dark:text-earth-300"}`}>
                    {sf.similarity}%
                  </span>
                  <span class="text-[10px] uppercase tracking-wide text-gray-400 dark:text-earth-500">match</span>
                </div>
              </div>
              <div class="mt-2 text-xs text-gray-500 dark:text-earth-400">
                {sf.sharedCount} shared {sf.sharedCount === 1 ? "herb" : "herbs"} of {sf.herbCount}
                {sf.sharedHerbs.length > 0 && (
                  <span class="ml-1 text-gray-400 dark:text-earth-500">— {sf.sharedHerbs.slice(0, 4).join(", ")}{sf.sharedHerbs.length > 4 ? ` +${sf.sharedHerbs.length - 4}` : ""}</span>
                )}
              </div>
            </a>
          ))}
        </div>
        <p class="text-xs text-gray-400 dark:text-earth-500 mt-3 italic">
          Match score combines dosage-weighted composition (cosine, 70%) with shared-herb overlap (Jaccard, 30%).
        </p>
      </section>
    )}

    {/* Inline TCM Clinical Evidence */}
    {tcmEvidence.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Clinical Evidence</h2>
        <div class="space-y-3">
          {tcmEvidence.map((ev: any) => (
            <div class="bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 p-4">
              <div class="flex items-center justify-between flex-wrap gap-2">
                <h3 class="font-medium text-gray-900 dark:text-earth-100">{ev.title}</h3>
                <div class="flex gap-2 text-xs text-gray-500 dark:text-earth-400">
                  {ev.evidence_id && <span class="font-mono">{ev.evidence_id}</span>}
                  {ev.source_db && <span class="px-2 py-0.5 rounded-full bg-gray-100 dark:bg-earth-800">{ev.source_db}</span>}
                </div>
              </div>
              {ev.study_type?.length > 0 && (
                <div class="flex flex-wrap gap-1 mt-1">
                  {ev.study_type.map((s: string) => <span class="text-xs px-2 py-0.5 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300">{s}</span>)}
                </div>
              )}
              {ev.summary && <div class="text-sm text-gray-600 dark:text-earth-300 mt-2 prose prose-sm dark:prose-invert" set:html={ev.summary} />}
              {ev.outcome && <div class="text-sm text-gray-600 dark:text-earth-300 mt-2"><span class="font-medium">Outcome:</span> <div class="prose prose-sm dark:prose-invert inline" set:html={ev.outcome} /></div>}
              {ev.source_url && <a href={ev.source_url} target="_blank" rel="noopener" class="text-xs text-sage-600 hover:underline mt-2 inline-block">Source →</a>}
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- TODO Phase 6: Add <SimilarFormulas client:visible />, <FormulaNetwork client:visible />, <ExplainToPatientButton client:load /> React islands -->
  </div>
</ContentLayout>
