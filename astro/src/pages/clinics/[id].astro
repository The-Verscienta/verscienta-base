---
import ContentLayout from "@/layouts/ContentLayout.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import { directus, readItems, readItem } from "@/lib/directus";
const { id } = Astro.params;
let clinic: any = null;
try {
  const bySlug = await directus.request(readItems("clinics", {
    filter: { slug: { _eq: id } },
    fields: [
      "*",
      "practitioners.practitioners_id.id",
      "practitioners.practitioners_id.first_name",
      "practitioners.practitioners_id.last_name",
      "practitioners.practitioners_id.title",
      "practitioners.practitioners_id.slug",
      "practitioners.practitioners_id.practice_type",
      "practitioners.practitioners_id.bio",
      "modalities.modalities_id.id",
      "modalities.modalities_id.title",
      "modalities.modalities_id.slug",
    ],
    limit: 1,
  }));
  clinic = bySlug?.[0] || null;
  if (!clinic && /^\d+$/.test(id!)) {
    clinic = await directus.request(readItem("clinics", parseInt(id!), {
      fields: ["*", "practitioners.practitioners_id.*", "modalities.modalities_id.*"],
    }));
  }
} catch (e) { console.error(e); }
if (!clinic) return Astro.redirect("/404");

const practitioners = (clinic.practitioners || [])
  .map((p: any) => p.practitioners_id)
  .filter(Boolean);

const modalities = (clinic.modalities || [])
  .map((m: any) => m.modalities_id)
  .filter(Boolean);

function practitionerName(p: any): string {
  return [p.first_name, p.last_name].filter(Boolean).join(" ") || p.title || "Unknown";
}

function formatAddress(): string[] {
  const lines = [];
  if (clinic.street_address) lines.push(clinic.street_address);
  if (clinic.suite_unit) lines.push(clinic.suite_unit);
  const cityState = [clinic.city, clinic.state].filter(Boolean).join(", ");
  if (cityState || clinic.zip_code) lines.push(`${cityState}${clinic.zip_code ? ` ${clinic.zip_code}` : ""}`);
  if (lines.length === 0 && clinic.address) lines.push(clinic.address);
  return lines;
}

const addressLines = formatAddress();

const TYPE_COLORS: Record<string, string> = {
  tcm: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300',
  western_herbalism: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300',
  naturopathy: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
  ayurveda: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300',
  integrative: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
  other: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
};

const TYPE_LABELS: Record<string, string> = {
  tcm: 'TCM', western_herbalism: 'Western Herbalism', naturopathy: 'Naturopathy',
  ayurveda: 'Ayurveda', integrative: 'Integrative', other: 'Other',
};
---

<ContentLayout title={`${clinic.name} — Verscienta Health`} description={`${clinic.name} — holistic health clinic.`}>
  <section class="bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Clinics", href: "/clinics" }, { label: clinic.name }]} class="mb-4" />
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 dark:text-earth-100 mb-2">{clinic.name}</h1>
      {clinic.accepts_insurance && (
        <span class="text-xs px-3 py-1 rounded-full bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-300">Accepts Insurance</span>
      )}
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8 space-y-8">

    <!-- Contact & Address -->
    <div class="grid md:grid-cols-2 gap-6">
      {addressLines.length > 0 && (
        <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6">
          <h2 class="font-semibold text-gray-900 dark:text-earth-100 mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/></svg>
            Location
          </h2>
          <div class="text-gray-600 dark:text-earth-300 text-sm space-y-0.5">
            {addressLines.map(line => <div>{line}</div>)}
          </div>
        </div>
      )}

      {(clinic.phone || clinic.email || clinic.website) && (
        <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6">
          <h2 class="font-semibold text-gray-900 dark:text-earth-100 mb-3 flex items-center gap-2">
            <svg class="w-5 h-5 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            Contact
          </h2>
          <div class="space-y-2 text-sm">
            {clinic.phone && (
              <a href={`tel:${clinic.phone}`} class="flex items-center gap-2 text-gray-600 dark:text-earth-300 hover:text-sage-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
                {clinic.phone}
              </a>
            )}
            {clinic.email && (
              <a href={`mailto:${clinic.email}`} class="flex items-center gap-2 text-gray-600 dark:text-earth-300 hover:text-sage-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
                {clinic.email}
              </a>
            )}
            {clinic.website && (
              <a href={clinic.website.startsWith('http') ? clinic.website : `https://${clinic.website}`} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-gray-600 dark:text-earth-300 hover:text-sage-600 transition">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9"/></svg>
                {clinic.website.replace(/^https?:\/\//, '')}
              </a>
            )}
          </div>
        </div>
      )}
    </div>

    <!-- Hours -->
    {clinic.hours && typeof clinic.hours === 'object' && Object.keys(clinic.hours).length > 0 && (
      <section class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6">
        <h2 class="font-serif text-xl font-bold text-gray-900 dark:text-earth-100 mb-4">Hours</h2>
        <div class="grid grid-cols-2 gap-x-8 gap-y-1.5 text-sm max-w-sm">
          {Object.entries(clinic.hours).map(([day, hours]) => (
            <div class="flex justify-between col-span-2">
              <span class="capitalize text-gray-700 dark:text-earth-300">{day}</span>
              <span class="text-gray-600 dark:text-earth-400">{hours as string}</span>
            </div>
          ))}
        </div>
      </section>
    )}

    <!-- About -->
    {clinic.description && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">About</h2>
        <div class="prose prose-earth dark:prose-invert max-w-none" set:html={clinic.description} />
      </section>
    )}

    <!-- Services -->
    {clinic.services && clinic.services.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Services</h2>
        <div class="flex flex-wrap gap-2">
          {clinic.services.map((s: string) => (
            <span class="px-3 py-1.5 rounded-full bg-sage-100 dark:bg-sage-900/30 text-sage-700 dark:text-sage-300 text-sm">{s}</span>
          ))}
        </div>
      </section>
    )}

    <!-- Modalities -->
    {modalities.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Modalities</h2>
        <div class="flex flex-wrap gap-2">
          {modalities.map((m: any) => (
            <a href={`/modalities/${m.slug || m.id}`} class="px-3 py-1.5 rounded-full bg-purple-100 dark:bg-purple-900/30 text-purple-700 dark:text-purple-300 text-sm hover:bg-purple-200 transition">{m.title}</a>
          ))}
        </div>
      </section>
    )}

    <!-- Practitioners -->
    {practitioners.length > 0 && (
      <section>
        <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Practitioners</h2>
        <div class="grid sm:grid-cols-2 gap-4">
          {practitioners.map((p: any) => (
            <a href={`/practitioners/${p.slug || p.id}`} class="group bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 hover:border-sage-300 dark:hover:border-sage-700 hover:shadow-md transition-all p-5">
              <h3 class="font-serif text-lg font-bold text-gray-900 dark:text-earth-100 group-hover:text-sage-600 transition-colors mb-1">{practitionerName(p)}</h3>
              {p.practice_type && (
                <span class={`text-xs px-2 py-0.5 rounded-full ${TYPE_COLORS[p.practice_type] || TYPE_COLORS.other}`}>
                  {TYPE_LABELS[p.practice_type] || p.practice_type}
                </span>
              )}
              {p.bio && <p class="text-sm text-gray-600 dark:text-earth-400 mt-2 line-clamp-2" set:html={p.bio.replace(/<[^>]*>/g, '').slice(0, 120)} />}
            </a>
          ))}
        </div>
      </section>
    )}
  </div>
</ContentLayout>
