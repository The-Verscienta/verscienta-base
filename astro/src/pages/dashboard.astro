---
/**
 * Dashboard — authenticated user landing page.
 * Shows role-appropriate content, account management, and quick links.
 */
import ContentLayout from "@/layouts/ContentLayout.astro";
---

<ContentLayout title="Dashboard — Verscienta Health" description="Your Verscienta Health dashboard.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <!-- Loading state -->
    <div id="dash-loading" class="text-center py-20">
      <div class="inline-block w-8 h-8 border-4 border-sage-200 border-t-sage-600 rounded-full animate-spin"></div>
      <p class="mt-4 text-gray-500 dark:text-earth-400">Loading your dashboard...</p>
    </div>

    <!-- Not authenticated -->
    <div id="dash-unauthenticated" class="hidden text-center py-20">
      <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-earth-100 mb-4">Sign in Required</h1>
      <p class="text-gray-600 dark:text-earth-300 mb-6">Please sign in to access your dashboard.</p>
      <a href="/login" class="px-6 py-3 bg-gradient-to-r from-sage-600 to-earth-600 text-white font-medium rounded-xl shadow hover:shadow-lg transition-all">Sign In</a>
    </div>

    <!-- Authenticated dashboard -->
    <div id="dash-content" class="hidden">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-earth-100">
            Welcome back, <span id="dash-name"></span>
          </h1>
          <p class="text-gray-600 dark:text-earth-300 mt-1">
            <span id="dash-role-badge" class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium"></span>
            <span id="dash-email" class="ml-2 text-sm text-gray-500 dark:text-earth-400"></span>
          </p>
        </div>
      </div>

      <!-- Quick Actions Grid -->
      <h2 class="text-lg font-semibold text-gray-900 dark:text-earth-100 mb-4">Explore</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mb-10">
        <a href="/herbs" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-sage-100 dark:bg-sage-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-sage-600">Browse Herbs</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Explore medicinal herbs database</p>
            </div>
          </div>
        </a>

        <a href="/formulas" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-earth-100 dark:bg-earth-800 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-earth-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-earth-600">Formulas</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Traditional herbal formulas</p>
            </div>
          </div>
        </a>

        <a href="/symptom-checker" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-3 7h3m-3 4h3m-6-4h.01M9 16h.01" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-blue-600">Symptom Checker</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">AI-powered symptom analysis</p>
            </div>
          </div>
        </a>

        <a href="/favorites" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-red-100 dark:bg-red-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-red-500">Favorites</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Your saved herbs and formulas</p>
            </div>
          </div>
        </a>

        <a href="/practitioners" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-teal-100 dark:bg-teal-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-teal-600">Find Practitioners</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Locate holistic health providers</p>
            </div>
          </div>
        </a>

        <a href="/tools/herb-drug-interactions" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-orange-100 dark:bg-orange-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-orange-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-2.5L13.732 4.5c-.77-.833-2.694-.833-3.464 0L3.34 16.5c-.77.833.192 2.5 1.732 2.5z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-orange-600">Drug Interaction Checker</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Check herb-drug interactions</p>
            </div>
          </div>
        </a>

        <a href="/saved-reports" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-sage-100 dark:bg-sage-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-sage-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 5a2 2 0 012-2h10a2 2 0 012 2v16l-7-3.5L5 21V5z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-sage-600">Saved Reports</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Your AI analyses & explanations</p>
            </div>
          </div>
        </a>

        <a href="/tools/consultation-prep" class="group p-5 bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-blue-100 dark:bg-blue-900/30 rounded-lg flex items-center justify-center flex-shrink-0 text-xl">📝</div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-blue-600">Consultation Prep</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Get ready for your holistic visit</p>
            </div>
          </div>
        </a>

        <!-- Practitioner-only AI tools -->
        <a href="/tools/formula-constructor" id="dash-pro-formula" class="hidden group p-5 bg-white dark:bg-earth-900 rounded-xl border border-amber-200 dark:border-amber-800 shadow-sm hover:shadow-md transition-all relative">
          <span class="absolute top-2 right-2 text-[10px] px-1.5 py-0.5 rounded bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 font-semibold uppercase tracking-wide">Pro</span>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-amber-100 dark:bg-amber-900/30 rounded-lg flex items-center justify-center flex-shrink-0 text-xl">🧪</div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-amber-600">Formula Constructor</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">AI-built custom formulas</p>
            </div>
          </div>
        </a>

        <a href="/tools/safety-check" id="dash-pro-safety" class="hidden group p-5 bg-white dark:bg-earth-900 rounded-xl border border-amber-200 dark:border-amber-800 shadow-sm hover:shadow-md transition-all relative">
          <span class="absolute top-2 right-2 text-[10px] px-1.5 py-0.5 rounded bg-amber-100 dark:bg-amber-900/40 text-amber-700 dark:text-amber-300 font-semibold uppercase tracking-wide">Pro</span>
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-amber-100 dark:bg-amber-900/30 rounded-lg flex items-center justify-center flex-shrink-0 text-xl">🛡️</div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-amber-600">Patient Safety Check</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Patient-specific risk evaluation</p>
            </div>
          </div>
        </a>

        <!-- Professional-only card -->
        <a href="/practitioners" id="dash-pro-practitioners" class="hidden group p-5 bg-white dark:bg-earth-900 rounded-xl border border-amber-200 dark:border-amber-800 shadow-sm hover:shadow-md transition-all">
          <div class="flex items-center gap-3">
            <div class="w-10 h-10 bg-amber-100 dark:bg-amber-900/30 rounded-lg flex items-center justify-center flex-shrink-0">
              <svg class="w-5 h-5 text-amber-600" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-3-3v6m-7 4h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
            </div>
            <div>
              <h3 class="font-semibold text-gray-900 dark:text-earth-100 group-hover:text-amber-600">Practitioner Tools</h3>
              <p class="text-xs text-gray-500 dark:text-earth-400">Clinical notes, case studies & more</p>
            </div>
          </div>
        </a>
      </div>

      <!-- Account Management Section -->
      <h2 class="text-lg font-semibold text-gray-900 dark:text-earth-100 mb-4">Account</h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-10">

        <!-- Change Password -->
        <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 shadow-sm">
          <h3 class="font-semibold text-gray-900 dark:text-earth-100 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" /></svg>
            Change Password
          </h3>
          <form id="change-password-form" class="space-y-3">
            <div>
              <label class="block text-xs font-medium text-gray-600 dark:text-earth-400 mb-1">Current Password</label>
              <input type="password" name="currentPassword" required class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 dark:text-earth-400 mb-1">New Password</label>
              <input type="password" name="newPassword" required minlength="8" class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" />
            </div>
            <div>
              <label class="block text-xs font-medium text-gray-600 dark:text-earth-400 mb-1">Confirm New Password</label>
              <input type="password" name="confirmNewPassword" required class="w-full px-3 py-2 text-sm border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" />
            </div>
            <div id="password-msg" class="hidden text-sm rounded-lg p-2"></div>
            <button type="submit" class="w-full px-4 py-2 text-sm bg-sage-600 hover:bg-sage-700 text-white rounded-lg transition">Update Password</button>
          </form>
        </div>

        <!-- Newsletter & Preferences -->
        <div class="space-y-6">
          <!-- Newsletter Signup -->
          <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 shadow-sm">
            <h3 class="font-semibold text-gray-900 dark:text-earth-100 mb-2 flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" /></svg>
              Newsletter
            </h3>
            <p class="text-sm text-gray-500 dark:text-earth-400 mb-3">Get weekly updates on new herbs, research, and health tips.</p>
            <div class="flex items-center gap-3">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="newsletter-toggle" class="sr-only peer" />
                <div class="w-11 h-6 bg-gray-200 peer-focus:ring-2 peer-focus:ring-sage-300 dark:peer-focus:ring-sage-800 rounded-full peer dark:bg-earth-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:after:border-earth-600 peer-checked:bg-sage-600"></div>
              </label>
              <span id="newsletter-status" class="text-sm text-gray-600 dark:text-earth-400">Subscribe to newsletter</span>
            </div>
          </div>

          <!-- Preferred Practitioner -->
          <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 shadow-sm">
            <h3 class="font-semibold text-gray-900 dark:text-earth-100 mb-2 flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
              My Practitioner
            </h3>
            <p class="text-sm text-gray-500 dark:text-earth-400 mb-3">Set a preferred practitioner for personalized recommendations.</p>
            <div id="preferred-practitioner-display" class="hidden flex items-center justify-between p-3 bg-sage-50 dark:bg-sage-900/20 rounded-lg mb-2">
              <span id="preferred-practitioner-name" class="text-sm font-medium text-sage-800 dark:text-sage-200"></span>
              <button id="remove-practitioner-btn" class="text-xs text-red-500 hover:text-red-700">Remove</button>
            </div>
            <a href="/practitioners" class="inline-flex items-center gap-1 text-sm text-sage-600 dark:text-sage-400 hover:underline">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
              Browse practitioners
            </a>
          </div>

          <!-- Theme Preference -->
          <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 shadow-sm">
            <h3 class="font-semibold text-gray-900 dark:text-earth-100 mb-2 flex items-center gap-2">
              <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" /></svg>
              Appearance
            </h3>
            <div class="flex items-center gap-3">
              <label class="relative inline-flex items-center cursor-pointer">
                <input type="checkbox" id="theme-toggle" class="sr-only peer" />
                <div class="w-11 h-6 bg-gray-200 peer-focus:ring-2 peer-focus:ring-sage-300 dark:peer-focus:ring-sage-800 rounded-full peer dark:bg-earth-700 peer-checked:after:translate-x-full peer-checked:after:border-white after:content-[''] after:absolute after:top-[2px] after:start-[2px] after:bg-white after:border-gray-300 after:border after:rounded-full after:h-5 after:w-5 after:transition-all dark:after:border-earth-600 peer-checked:bg-sage-600"></div>
              </label>
              <span id="theme-label" class="text-sm text-gray-600 dark:text-earth-400">Dark mode</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Danger Zone -->
      <div class="border border-red-200 dark:border-red-800/50 rounded-xl p-6">
        <h3 class="text-sm font-semibold text-red-600 dark:text-red-400 mb-3">Account Actions</h3>
        <div class="flex flex-wrap gap-3">
          <button id="dash-logout-btn" class="px-4 py-2 text-sm border border-gray-300 dark:border-earth-600 text-gray-700 dark:text-earth-300 rounded-lg hover:bg-gray-100 dark:hover:bg-earth-800 transition">Sign Out</button>
        </div>
      </div>
    </div>
  </div>

  <script>
    import { apiFetch } from "../lib/api-client";

    (async function loadDashboard() {
      const loading = document.getElementById('dash-loading')!;
      const unauthenticated = document.getElementById('dash-unauthenticated')!;
      const content = document.getElementById('dash-content')!;

      try {
        const res = await fetch('/api/auth/me');
        const data = await res.json();

        loading.classList.add('hidden');

        if (!data.user) {
          unauthenticated.classList.remove('hidden');
          return;
        }

        const user = data.user;
        content.classList.remove('hidden');

        // Set name & email
        const nameEl = document.getElementById('dash-name');
        if (nameEl) nameEl.textContent = user.first_name || user.email?.split('@')[0] || 'there';
        const emailEl = document.getElementById('dash-email');
        if (emailEl) emailEl.textContent = user.email;

        // Set role badge
        const badge = document.getElementById('dash-role-badge');
        if (badge) {
          const roleName = user.role?.name || 'Member';
          const isPro = roleName === 'Professional';
          badge.textContent = roleName;
          badge.className = `inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${
            isPro
              ? 'bg-amber-100 text-amber-800 dark:bg-amber-900/30 dark:text-amber-300'
              : 'bg-sage-100 text-sage-800 dark:bg-sage-900/30 dark:text-sage-300'
          }`;

          if (isPro) {
            document.getElementById('dash-pro-practitioners')?.classList.remove('hidden');
            document.getElementById('dash-pro-formula')?.classList.remove('hidden');
            document.getElementById('dash-pro-safety')?.classList.remove('hidden');
          }
        }
      } catch {
        loading.classList.add('hidden');
        unauthenticated.classList.remove('hidden');
      }
    })();

    // ── Change Password ─────────────────────────────────────────────
    document.getElementById('change-password-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const form = e.target as HTMLFormElement;
      const formData = new FormData(form);
      const msgEl = document.getElementById('password-msg')!;

      const newPassword = formData.get('newPassword') as string;
      const confirmNewPassword = formData.get('confirmNewPassword') as string;

      if (newPassword !== confirmNewPassword) {
        msgEl.textContent = 'New passwords do not match.';
        msgEl.className = 'text-sm rounded-lg p-2 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300';
        msgEl.classList.remove('hidden');
        return;
      }

      try {
        const res = await apiFetch('/api/auth/profile', {
          method: 'PATCH',
          body: JSON.stringify({ password: newPassword }),
        });

        if (res.ok) {
          msgEl.textContent = 'Password updated successfully.';
          msgEl.className = 'text-sm rounded-lg p-2 bg-green-50 dark:bg-green-900/20 text-green-700 dark:text-green-300';
          form.reset();
        } else {
          const data = await res.json();
          msgEl.textContent = data.error || 'Failed to update password.';
          msgEl.className = 'text-sm rounded-lg p-2 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300';
        }
      } catch {
        msgEl.textContent = 'Something went wrong. Please try again.';
        msgEl.className = 'text-sm rounded-lg p-2 bg-red-50 dark:bg-red-900/20 text-red-700 dark:text-red-300';
      }
      msgEl.classList.remove('hidden');
    });

    // ── Theme Toggle ────────────────────────────────────────────────
    const themeToggle = document.getElementById('theme-toggle') as HTMLInputElement;
    const themeLabel = document.getElementById('theme-label')!;
    if (themeToggle) {
      const isDark = document.documentElement.classList.contains('dark');
      themeToggle.checked = isDark;
      themeLabel.textContent = isDark ? 'Dark mode on' : 'Dark mode off';

      themeToggle.addEventListener('change', () => {
        if (themeToggle.checked) {
          document.documentElement.classList.add('dark');
          localStorage.setItem('verscienta_theme', 'dark');
          themeLabel.textContent = 'Dark mode on';
        } else {
          document.documentElement.classList.remove('dark');
          localStorage.setItem('verscienta_theme', 'light');
          themeLabel.textContent = 'Dark mode off';
        }
      });
    }

    // ── Newsletter Toggle ───────────────────────────────────────────
    const nlToggle = document.getElementById('newsletter-toggle') as HTMLInputElement;
    const nlStatus = document.getElementById('newsletter-status')!;
    if (nlToggle) {
      const stored = localStorage.getItem('verscienta_newsletter');
      nlToggle.checked = stored === 'subscribed';
      nlStatus.textContent = nlToggle.checked ? 'Subscribed' : 'Subscribe to newsletter';

      nlToggle.addEventListener('change', () => {
        if (nlToggle.checked) {
          localStorage.setItem('verscienta_newsletter', 'subscribed');
          nlStatus.textContent = 'Subscribed';
        } else {
          localStorage.setItem('verscienta_newsletter', 'unsubscribed');
          nlStatus.textContent = 'Subscribe to newsletter';
        }
      });
    }

    // ── Logout ──────────────────────────────────────────────────────
    document.getElementById('dash-logout-btn')?.addEventListener('click', async () => {
      try { await fetch('/api/auth/logout', { method: 'POST' }); } catch {}
      window.location.href = '/login';
    });
  </script>
</ContentLayout>
