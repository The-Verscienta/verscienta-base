---
import ContentLayout from "@/layouts/ContentLayout.astro";
---
<ContentLayout title="TCM Patterns — Verscienta Health" description="Traditional Chinese Medicine diagnostic patterns and syndromes.">
  <section class="bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <span class="text-sage-600 font-medium tracking-wide uppercase text-sm">Pattern Differentiation</span>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 dark:text-earth-100 mb-4 mt-2">TCM Patterns</h1>
      <p class="text-lg text-gray-600 dark:text-earth-300">Traditional Chinese Medicine diagnostic patterns (辨证 biànzhèng) for syndrome differentiation.</p>
    </div>
  </section>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="bg-white dark:bg-earth-900 rounded-2xl border border-gray-100 dark:border-earth-700 p-8 text-center">
      <span class="text-5xl block mb-4">☯️</span>
      <p class="text-gray-600 dark:text-earth-300 mb-4">TCM patterns will be populated as content is added to the database.</p>
      <a href="/symptom-checker" class="inline-flex items-center gap-2 px-4 py-2 bg-sage-600 text-white rounded-lg hover:bg-sage-700 transition">Try the AI Symptom Checker</a>
    </div>
  </div>
</ContentLayout>
