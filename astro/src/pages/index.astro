---
/**
 * Homepage — hero, search, featured sections.
 * Minimal version; full port in Phase 5.
 */
import ContentLayout from "@/layouts/ContentLayout.astro";
---

<ContentLayout
  title="Verscienta Health — Herb Database & TCM Resource"
  description="Comprehensive herb database integrating Traditional Chinese Medicine and Western herbalism with modern research, AI symptom checker, and dosage tools."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="absolute top-20 left-10 w-64 h-64 bg-sage-300/20 rounded-full blur-3xl"></div>
    <div class="absolute bottom-10 right-20 w-48 h-48 bg-earth-300/15 rounded-full blur-3xl"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="font-serif text-5xl md:text-6xl lg:text-7xl font-bold text-gray-900 dark:text-earth-100 mb-6 leading-tight">
          Ancient Wisdom,<br />
          <span class="text-sage-600 dark:text-sage-400">Modern Science</span>
        </h1>

        <p class="text-xl md:text-2xl text-gray-600 dark:text-earth-300 leading-relaxed mb-8">
          Explore our comprehensive database of medicinal herbs, traditional formulas,
          and holistic health modalities — backed by research and rooted in tradition.
        </p>

        <div class="flex flex-wrap gap-4">
          <a
            href="/herbs"
            class="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-sage-600 to-earth-600 text-white font-medium rounded-xl shadow-lg hover:shadow-xl transition-all hover:scale-105"
          >
            <span>Explore Herbs</span>
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
            </svg>
          </a>

          <a
            href="/symptom-checker"
            class="inline-flex items-center gap-2 px-6 py-3 bg-white dark:bg-earth-800 text-earth-700 dark:text-earth-200 font-medium rounded-xl border border-earth-200 dark:border-earth-600 shadow-sm hover:shadow-md transition-all"
          >
            <span>AI Symptom Checker</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Stats -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
      {[
        { label: "Medicinal Herbs", value: "500+", icon: "🌿" },
        { label: "TCM Formulas", value: "200+", icon: "📜" },
        { label: "Health Conditions", value: "150+", icon: "🩺" },
        { label: "Healing Modalities", value: "30+", icon: "🧘" },
      ].map(({ label, value, icon }) => (
        <div class="bg-white dark:bg-earth-900 rounded-xl shadow-sm border border-gray-100 dark:border-earth-700 p-6 text-center">
          <div class="text-3xl mb-2">{icon}</div>
          <div class="font-serif text-2xl font-bold text-earth-800 dark:text-earth-100">{value}</div>
          <div class="text-sm text-gray-600 dark:text-earth-400">{label}</div>
        </div>
      ))}
    </div>
  </section>

  <!-- Features Grid -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <h2 class="font-serif text-3xl font-bold text-gray-900 dark:text-earth-100 mb-8 text-center">
      What You Can Do
    </h2>

    <div class="grid md:grid-cols-3 gap-6">
      <a href="/symptom-checker" class="group bg-white dark:bg-earth-900 rounded-xl shadow-sm border border-gray-100 dark:border-earth-700 p-6 hover:shadow-lg transition-all">
        <div class="w-12 h-12 bg-sage-100 dark:bg-earth-800 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <span class="text-2xl">🔍</span>
        </div>
        <h3 class="font-serif text-xl font-bold text-gray-900 dark:text-earth-100 mb-2">AI Symptom Checker</h3>
        <p class="text-sm text-gray-600 dark:text-earth-400">
          Describe your symptoms and get TCM pattern analysis with herb and modality recommendations.
        </p>
      </a>

      <a href="/tools/herb-drug-interactions" class="group bg-white dark:bg-earth-900 rounded-xl shadow-sm border border-gray-100 dark:border-earth-700 p-6 hover:shadow-lg transition-all">
        <div class="w-12 h-12 bg-sage-100 dark:bg-earth-800 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <span class="text-2xl">💊</span>
        </div>
        <h3 class="font-serif text-xl font-bold text-gray-900 dark:text-earth-100 mb-2">Drug Interaction Checker</h3>
        <p class="text-sm text-gray-600 dark:text-earth-400">
          Check potential interactions between herbs and pharmaceutical medications.
        </p>
      </a>

      <a href="/search" class="group bg-white dark:bg-earth-900 rounded-xl shadow-sm border border-gray-100 dark:border-earth-700 p-6 hover:shadow-lg transition-all">
        <div class="w-12 h-12 bg-sage-100 dark:bg-earth-800 rounded-xl flex items-center justify-center mb-4 group-hover:scale-110 transition-transform">
          <span class="text-2xl">📚</span>
        </div>
        <h3 class="font-serif text-xl font-bold text-gray-900 dark:text-earth-100 mb-2">Search Database</h3>
        <p class="text-sm text-gray-600 dark:text-earth-400">
          Search across herbs, formulas, conditions, and practitioners with faceted filtering.
        </p>
      </a>
    </div>
  </section>
</ContentLayout>
