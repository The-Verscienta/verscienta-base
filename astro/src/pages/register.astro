---
/**
 * Registration page — Astro shell.
 * TODO Phase 6: Port multi-step form + Turnstile as React island.
 */
import ContentLayout from "@/layouts/ContentLayout.astro";
---

<ContentLayout title="Register — Verscienta Health" description="Create a free Verscienta Health account.">
  <div class="min-h-[60vh] flex items-center justify-center py-16">
    <div class="w-full max-w-md px-4">
      <div class="text-center mb-8">
        <h1 class="font-serif text-3xl font-bold text-gray-900 dark:text-earth-100 mb-2">Create Account</h1>
        <p class="text-gray-600 dark:text-earth-300">Join Verscienta Health to save herbs, track formulas, and access personalized recommendations.</p>
      </div>

      <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 shadow-sm">
        <!-- TODO Phase 6: <RegisterForm client:load /> with multi-step + Turnstile -->
        <form class="space-y-4" id="register-form">
          <div class="grid grid-cols-2 gap-4">
            <div><label for="firstName" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">First Name</label><input type="text" id="firstName" name="firstName" required class="w-full px-4 py-2.5 border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" /></div>
            <div><label for="lastName" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Last Name</label><input type="text" id="lastName" name="lastName" required class="w-full px-4 py-2.5 border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" /></div>
          </div>
          <div><label for="email" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Email</label><input type="email" id="email" name="email" required class="w-full px-4 py-2.5 border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" /></div>
          <div><label for="password" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Password</label><input type="password" id="password" name="password" required minlength="8" class="w-full px-4 py-2.5 border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" /></div>
          <div><label for="confirmPassword" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Confirm Password</label><input type="password" id="confirmPassword" name="confirmPassword" required class="w-full px-4 py-2.5 border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500" /></div>
          <button type="submit" class="w-full px-6 py-3 bg-gradient-to-r from-sage-600 to-earth-600 text-white font-medium rounded-xl shadow hover:shadow-lg transition-all">Create Account</button>
        </form>
        <p class="mt-4 text-center text-sm text-gray-600 dark:text-earth-400">
          Already have an account? <a href="/login" class="text-sage-600 dark:text-sage-400 hover:underline">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</ContentLayout>
