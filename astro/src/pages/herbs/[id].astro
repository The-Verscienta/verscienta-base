                    </tr></thead>
                    <tbody>
                      {tcmTargets.map((t: any) => (
                        <tr class="border-b border-gray-100 dark:border-earth-800">
                          <td class="px-4 py-2 text-gray-900 dark:text-earth-100">{t.target_name || t.title}</td>
                          <td class="px-4 py-2 text-gray-600 dark:text-earth-300 font-mono text-xs">{t.gene_name || "—"}</td>
                          <td class="px-4 py-2 text-gray-600 dark:text-earth-300">
                            {t.uniprot_id ? <a href={`https://www.uniprot.org/uniprotkb/${t.uniprot_id}`} target="_blank" rel="noopener" class="text-sage-600 hover:underline font-mono text-xs">{t.uniprot_id}</a> : "—"}
                          </td>
                          <td class="px-4 py-2 text-gray-600 dark:text-earth-300">{t.score != null ? Number(t.score).toFixed(2) : "—"}</td>
                          <td class="px-4 py-2 text-xs">
                            {t.evidence_type?.length > 0 && (
                              <div class="flex flex-wrap gap-1">
                                {t.evidence_type.map((e: string) => <span class="px-1.5 py-0.5 rounded bg-gray-100 dark:bg-earth-800 text-gray-600 dark:text-earth-300">{e}</span>)}
                              </div>
                            )}
                          </td>
                          <td class="px-4 py-2 text-gray-500 dark:text-earth-400 text-xs">{t.source_db || "—"}</td>
                        </tr>
                      ))}
                    </tbody>
                  </table>
                </div>
              </div>
            )}

            {tcmEvidence.length > 0 && (
              <div>
                <h3 class="font-serif text-lg font-semibold text-gray-900 dark:text-earth-100 mb-2">Linked Clinical Evidence</h3>
                <div class="space-y-3">
                  {tcmEvidence.map((ev: any) => (
                    <div class="bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 p-4">
                      <div class="flex items-center justify-between flex-wrap gap-2">
                        <h4 class="font-medium text-gray-900 dark:text-earth-100">{ev.title}</h4>
                        <div class="flex gap-2 text-xs text-gray-500 dark:text-earth-400">
                          {ev.evidence_id && <span class="font-mono">{ev.evidence_id}</span>}
                          {ev.source_db && <span class="px-2 py-0.5 rounded-full bg-gray-100 dark:bg-earth-800">{ev.source_db}</span>}
                        </div>
                      </div>
                      {ev.study_type?.length > 0 && (
                        <div class="flex flex-wrap gap-1 mt-1">
                          {ev.study_type.map((s: string) => <span class="text-xs px-2 py-0.5 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300">{s}</span>)}
                        </div>
                      )}
                      {ev.summary && <div class="text-sm text-gray-600 dark:text-earth-300 mt-2 prose prose-sm dark:prose-invert" set:html={ev.summary} />}
                      {ev.outcome && <div class="text-sm text-gray-600 dark:text-earth-300 mt-2"><span class="font-medium">Outcome:</span> <div class="prose prose-sm dark:prose-invert inline" set:html={ev.outcome} /></div>}
                      {ev.source_url && <a href={ev.source_url} target="_blank" rel="noopener" class="text-xs text-sage-600 hover:underline mt-2 inline-block">Source →</a>}
                    </div>
                  ))}
                </div>
              </div>
            )}
          </section>
        )}

        {/* References (O2M) */}
        {herb.references?.length > 0 && (
          <section id="references" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">References</h2>
            <ol class="list-decimal list-inside space-y-2 text-sm text-gray-600 dark:text-earth-300">
              {herb.references.map((ref: any) => (
                <li>
                  {ref.type && <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-earth-800 text-gray-600 dark:text-earth-300 mr-2">{ref.type}</span>}
                  {ref.authors && <span>{ref.authors}. </span>}
                  <span class="font-medium text-gray-900 dark:text-earth-100">{ref.title}</span>
                  {ref.publication && <span class="italic">. {ref.publication}</span>}
                  {ref.year && <span> ({ref.year})</span>}
                  {ref.pages && <span>, pp. {ref.pages}</span>}
                  {ref.isbn && <span class="ml-1 text-xs text-gray-500">ISBN: {ref.isbn}</span>}
                  {ref.doi && <a href={`https://doi.org/${ref.doi}`} target="_blank" rel="noopener" class="text-sage-600 hover:underline ml-1">[DOI]</a>}
                  {ref.url && !ref.doi && <a href={ref.url} target="_blank" rel="noopener" class="text-sage-600 hover:underline ml-1">[Link]</a>}
                  {ref.notes && <div class="text-xs text-gray-500 dark:text-earth-400 mt-1 ml-5 whitespace-pre-line">{ref.notes}</div>}
                </li>
              ))}
            </ol>
          </section>
        )}
      </div>

      <!-- Sidebar -->
      <aside class="space-y-6">
        {/* Table of Contents */}
        <div class="bg-white/80 dark:bg-earth-900/80 backdrop-blur-sm rounded-2xl border border-earth-100 dark:border-earth-700 p-6 sticky top-20">
          <h3 class="text-xs font-bold text-gray-500 dark:text-earth-400 uppercase tracking-widest mb-3">On This Page</h3>
          <nav class="space-y-0.5 text-sm">
            {showTcm && <a href="#tcm" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">TCM Properties</a>}
            {showWestern && <a href="#western" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Western Properties</a>}
            {herb.therapeutic_uses && <a href="#therapeutic" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Therapeutic Uses</a>}
            {herb.pharmacological_effects && <a href="#pharmacology" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Pharmacology</a>}
            {herb.images?.length > 1 && <a href="#gallery" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Gallery</a>}
            {showBotanical && <a href="#botanical" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Botanical Description</a>}
            {herb.constituents?.length > 0 && <a href="#constituents" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Active Constituents</a>}
            {herb.drug_interactions?.length > 0 && <a href="#interactions" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Drug Interactions</a>}
            {herb.dosages?.length > 0 && <a href="#dosage" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Dosage</a>}
            {herb.preparations?.length > 0 && <a href="#preparations" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Preparation</a>}
            {herb.clinical_studies?.length > 0 && <a href="#studies" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Clinical Studies</a>}
            {herb.case_studies?.length > 0 && <a href="#case-studies" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Case Studies</a>}
            {herb.practitioner_notes?.length > 0 && <a href="#practitioner-notes" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Practitioner Notes</a>}
            {showSafety && <a href="#safety" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Safety</a>}
            {showToxicity && <a href="#toxicity" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Toxicity</a>}
            {showStorage && <a href="#storage" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Storage</a>}
            {showSourcing && <a href="#sourcing" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Sourcing</a>}
            {showCultural && <a href="#cultural" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Cultural &amp; Historical</a>}
            {herb.historical_texts?.length > 0 && <a href="#history" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Historical Refs</a>}
            {showQuality && <a href="#quality" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Quality &amp; Regulatory</a>}
            {showChemistry && <a href="#chemistry" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">Chemistry</a>}
            {(tcmIngredients.length > 0 || tcmTargets.length > 0 || tcmEvidence.length > 0) && <a href="#tcm-database" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">TCM Database</a>}
            {herb.references?.length > 0 && <a href="#references" class="block py-1.5 px-3 text-gray-600 dark:text-earth-300 hover:bg-earth-50 dark:hover:bg-earth-800 rounded-lg transition">References</a>}
          </nav>
        </div>

        {/* Quick facts card */}
        <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6">
          <h3 class="font-serif text-lg font-bold text-gray-900 dark:text-earth-100 mb-4">Quick Facts</h3>
          <dl class="space-y-3 text-sm">
            {herb.plant_type && <div><dt class="text-gray-500 dark:text-earth-400">Type</dt><dd class="font-medium capitalize">{herb.plant_type}</dd></div>}
            {herb.parts_used?.length > 0 && <div><dt class="text-gray-500 dark:text-earth-400">Parts Used</dt><dd class="font-medium">{herb.parts_used.join(", ")}</dd></div>}
            {herb.conservation_status && <div><dt class="text-gray-500 dark:text-earth-400">Conservation</dt><dd class="font-medium capitalize">{herb.conservation_status.replace(/_/g, " ")}</dd></div>}
            {herb.western_properties?.length > 0 && <div><dt class="text-gray-500 dark:text-earth-400">Western Actions</dt><dd class="flex flex-wrap gap-1 mt-1">{herb.western_properties.map((p: string) => <span class="text-xs px-2 py-0.5 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300 capitalize">{p}</span>)}</dd></div>}
            {herb.dosage_forms?.length > 0 && <div><dt class="text-gray-500 dark:text-earth-400">Available Forms</dt><dd class="font-medium capitalize">{herb.dosage_forms.join(", ")}</dd></div>}
            {(has(herb.typical_dose_min) || has(herb.typical_dose_max)) && (
              <div>
                <dt class="text-gray-500 dark:text-earth-400">Typical Dose</dt>
                <dd class="font-medium">
                  {has(herb.typical_dose_min) ? fmtNum(herb.typical_dose_min) : "?"}
                  –{has(herb.typical_dose_max) ? fmtNum(herb.typical_dose_max) : "?"}
                  {herb.typical_dose_unit || ""}
                </dd>
              </div>
            )}
            {herb.peer_review_status && <div><dt class="text-gray-500 dark:text-earth-400">Review Status</dt><dd class="font-medium">{herb.peer_review_status}</dd></div>}
            {herb.average_rating && (
              <div>
                <dt class="text-gray-500 dark:text-earth-400">Rating</dt>
                <dd class="font-medium">
                  {Number(herb.average_rating).toFixed(1)} / 5
                  {herb.review_count ? <span class="text-xs text-gray-500 ml-1">({herb.review_count} reviews)</span> : null}
                </dd>
              </div>
            )}
            {herb.version && <div><dt class="text-gray-500 dark:text-earth-400">Version</dt><dd class="font-medium">{herb.version}</dd></div>}
          </dl>

          {/* Conditions treated */}
          {herb.conditions_treated?.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Conditions Treated</h4>
              <div class="flex flex-wrap gap-1">
                {herb.conditions_treated.map((ct: any) => (
                  <a href={`/conditions/${ct.conditions_id?.slug || ct.conditions_id?.id}`} class="text-xs px-2 py-1 rounded-full bg-blue-100 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 hover:bg-blue-200 transition">
                    {ct.conditions_id?.title}
                  </a>
                ))}
              </div>
            </div>
          )}

          {/* Tags */}
          {herb.tags?.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Tags</h4>
              <div class="flex flex-wrap gap-1">
                {herb.tags.map((t: any) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-earth-800 text-gray-600 dark:text-earth-300">{t.herb_tags_id?.name}</span>
                ))}
              </div>
            </div>
          )}

          {/* Keywords */}
          {herb.keywords?.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Keywords</h4>
              <div class="flex flex-wrap gap-1">
                {herb.keywords.map((k: string) => (
                  <span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-earth-800 text-gray-600 dark:text-earth-300">{k}</span>
                ))}
              </div>
            </div>
          )}

          {/* Related species */}
          {herb.related_species?.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Related Species</h4>
              <ul class="space-y-1">
                {herb.related_species.map((rs: any) => (
                  <li><a href={`/herbs/${rs.related_herbs_id?.slug || rs.related_herbs_id?.id}`} class="text-sm text-sage-600 dark:text-sage-400 hover:underline">{rs.related_herbs_id?.title}</a></li>
                ))}
              </ul>
            </div>
          )}

          {/* Substitute herbs */}
          {herb.substitute_herbs?.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Substitutes</h4>
              <ul class="space-y-1">
                {herb.substitute_herbs.map((sh: any) => (
                  <li><a href={`/herbs/${sh.substitute_herbs_id?.slug || sh.substitute_herbs_id?.id}`} class="text-sm text-sage-600 dark:text-sage-400 hover:underline">{sh.substitute_herbs_id?.title}</a></li>
                ))}
              </ul>
            </div>
          )}

          {/* Similar TCM herbs */}
          {herb.similar_tcm_herbs?.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Similar TCM Herbs</h4>
              <ul class="space-y-1">
                {herb.similar_tcm_herbs.map((sh: any) => (
                  <li><a href={`/herbs/${sh.similar_tcm_id?.slug || sh.similar_tcm_id?.id}`} class="text-sm text-sage-600 dark:text-sage-400 hover:underline">{sh.similar_tcm_id?.title}</a></li>
                ))}
              </ul>
            </div>
          )}

          {/* Similar Western herbs */}
          {herb.similar_western_herbs?.length > 0 && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Similar Western Herbs</h4>
              <ul class="space-y-1">
                {herb.similar_western_herbs.map((sh: any) => (
                  <li><a href={`/herbs/${sh.similar_western_id?.slug || sh.similar_western_id?.id}`} class="text-sm text-sage-600 dark:text-sage-400 hover:underline">{sh.similar_western_id?.title}</a></li>
                ))}
              </ul>
            </div>
          )}

          {/* Contributors */}
          {has(herb.contributors) && (
            <div class="mt-6 pt-6 border-t border-gray-100 dark:border-earth-700">
              <h4 class="text-sm font-semibold text-gray-500 dark:text-earth-400 uppercase tracking-wide mb-2">Contributors</h4>
              <ul class="text-xs space-y-1">
                {(Array.isArray(herb.contributors) ? herb.contributors : [herb.contributors]).map((c: any) => (
                  <li>{renderJsonItem(c)}</li>
                ))}
              </ul>
            </div>
          )}
        </div>
      </aside>
    </div>
  </div>

  <!-- Disclaimer + Back Link -->
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-8">
    <BotanicalDivider />
    <DisclaimerBox>
      <p>This information is for educational purposes only and is not intended to replace professional medical advice. Always consult a qualified healthcare provider before using any herbal remedy, especially if you are pregnant, nursing, or taking medications.</p>
    </DisclaimerBox>
    <BackLink href="/herbs" label="Back to Herb Database" />
  </div>
</ContentLayout>
