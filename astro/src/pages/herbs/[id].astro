---
/**
 * Herb detail page — server-rendered with all fields and O2M children from Directus.
 */
import ContentLayout from "@/layouts/ContentLayout.astro";
import DisclaimerBox from "@/components/ui/DisclaimerBox.astro";
import BotanicalDivider from "@/components/ui/BotanicalDivider.astro";
import Breadcrumbs from "@/components/ui/Breadcrumbs.astro";
import BackLink from "@/components/ui/BackLink.astro";
import { directus, readItems } from "@/lib/directus";
import { imageUrl } from "@/lib/image-url";

const { id } = Astro.params;

const HERB_FIELDS = [
  "*",
  "clinical_studies.*",
  "drug_interactions.*",
  "dosages.*",
  "constituents.*",
  "preparations.*",
  "historical_texts.*",
  "practitioner_notes.*",
  "case_studies.*",
  "case_studies.condition_id.id",
  "case_studies.condition_id.title",
  "case_studies.condition_id.slug",
  "references.*",
  "images.*",
  "images.file.*",
  "conditions_treated.conditions_id.id",
  "conditions_treated.conditions_id.title",
  "conditions_treated.conditions_id.slug",
  "related_species.related_herbs_id.id",
  "related_species.related_herbs_id.title",
  "related_species.related_herbs_id.slug",
  "substitute_herbs.substitute_herbs_id.id",
  "substitute_herbs.substitute_herbs_id.title",
  "substitute_herbs.substitute_herbs_id.slug",
  "similar_tcm_herbs.similar_tcm_id.id",
  "similar_tcm_herbs.similar_tcm_id.title",
  "similar_tcm_herbs.similar_tcm_id.slug",
  "similar_western_herbs.similar_western_id.id",
  "similar_western_herbs.similar_western_id.title",
  "similar_western_herbs.similar_western_id.slug",
  "tags.herb_tags_id.id",
  "tags.herb_tags_id.name",
  "tags.herb_tags_id.slug",
  "tcm_category_tags.tcm_categories_id.id",
  "tcm_category_tags.tcm_categories_id.name",
];

let herb: any = null;

try {
  const bySlug = await directus.request(
    readItems("herbs", {
      filter: { slug: { _eq: id }, status: { _eq: "published" } },
      fields: HERB_FIELDS,
      limit: 1,
    })
  );
  herb = bySlug?.[0] || null;

  if (!herb && /^\d+$/.test(id!)) {
    const byId = await directus.request(
      readItems("herbs", {
        filter: { id: { _eq: parseInt(id!) }, status: { _eq: "published" } },
        fields: HERB_FIELDS,
        limit: 1,
      })
    );
    herb = byId?.[0] || null;
  }
} catch (e) {
  console.error("Error fetching herb:", e);
}

if (!herb) {
  return Astro.redirect("/404");
}

// Inline TCM cross-references (these collections have no own UI page)
let tcmIngredients: any[] = [];
let tcmTargets: any[] = [];
let tcmEvidence: any[] = [];
try {
  [tcmIngredients, tcmTargets, tcmEvidence] = await Promise.all([
    directus.request(readItems("tcm_ingredients", {
      filter: { herb_sources: { herbs_id: { _eq: herb.id } } },
      fields: ["id", "title", "pubchem_cid", "cas_number", "molecular_weight", "source_db"],
      limit: 50,
    })).catch(() => []),
    directus.request(readItems("tcm_target_interactions", {
      filter: { herb_id: { _eq: herb.id } },
      fields: ["id", "title", "target_name", "uniprot_id", "gene_name", "score", "evidence_type", "source_db"],
      sort: ["-score"],
      limit: 50,
    })).catch(() => []),
    directus.request(readItems("tcm_clinical_evidence", {
      filter: { herb_refs: { herbs_id: { _eq: herb.id } } },
      fields: ["id", "title", "evidence_id", "study_type", "summary", "outcome", "source_url", "source_db"],
      limit: 20,
    })).catch(() => []),
  ]);
} catch (e) {
  console.error("Error fetching TCM cross-refs:", e);
}

const title = `${herb.title} (${herb.scientific_name || ""}) — Verscienta Health`;

// Helpers
const has = (v: any) => v !== null && v !== undefined && v !== "" && !(Array.isArray(v) && v.length === 0);
const renderJsonItem = (item: any): string => {
  if (item == null) return "";
  if (typeof item === "string" || typeof item === "number") return String(item);
  if (Array.isArray(item)) return item.map(renderJsonItem).join(", ");
  if (typeof item === "object") {
    return Object.entries(item)
      .filter(([, v]) => v !== null && v !== undefined && v !== "")
      .map(([k, v]) => `${k.replace(/_/g, " ")}: ${typeof v === "object" ? JSON.stringify(v) : v}`)
      .join(" · ");
  }
  return String(item);
};

// Trim trailing zeros, cap at 2 decimal places. "87.00000" → "87", "87.567" → "87.57"
const fmtNum = (v: any): string => {
  if (v == null || v === "") return "";
  const n = Number(v);
  return Number.isFinite(n) ? String(parseFloat(n.toFixed(2))) : String(v);
};

const showTcm = has(herb.tcm_taste) || has(herb.tcm_temperature) || has(herb.tcm_meridians) || has(herb.tcm_functions) || has(herb.tcm_category) || has(herb.tcm_category_tags);
const showWestern = has(herb.western_properties) || has(herb.dosage_forms);
const showBotanical = has(herb.botanical_description) || has(herb.habitat) || has(herb.native_region) || has(herb.conservation_notes);
const showSafety = has(herb.contraindications) || has(herb.side_effects) || has(herb.allergenic_potential) || has(herb.safety_warnings) || has(herb.adulteration_risks);
const showStorage = has(herb.storage_conditions) || has(herb.storage_temperature) || has(herb.storage_light) || has(herb.storage_humidity) || has(herb.storage_shelf_life) || has(herb.storage_degradation_signs);
const showSourcing = has(herb.sourcing_type) || herb.sourcing_organic === true || herb.sourcing_fair_trade === true || has(herb.sourcing_sustainability) || has(herb.sourcing_suppliers) || has(herb.sourcing_harvest_season);
const showCultural = has(herb.traditional_american_uses) || has(herb.traditional_chinese_uses) || has(herb.native_american_uses) || has(herb.cultural_significance) || has(herb.ethnobotanical_notes) || has(herb.folklore);
const showQuality = has(herb.quality_standards) || has(herb.regulatory_status);
const showChemistry = has(herb.pubchem_cid) || has(herb.smiles) || has(herb.molecular_weight) || has(herb.source_databases) || has(herb.trefle_id) || has(herb.perenual_id) || has(herb.external_ids);
const showToxicity = has(herb.toxicity_level) && herb.toxicity_level !== "none_known" && herb.toxicity_level !== "None Known";
---

<ContentLayout title={title} description={`Comprehensive information about ${herb.title} including TCM properties, clinical studies, dosage, and safety data.`}>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <Breadcrumbs items={[{ label: "Home", href: "/" }, { label: "Herbs", href: "/herbs" }, { label: herb.title }]} class="mb-4" />
      <div class="flex flex-col md:flex-row gap-8">
        <div class="flex-1">
          <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 dark:text-earth-100 mb-2">{herb.title}</h1>
          {herb.scientific_name && <p class="text-xl italic text-sage-600 dark:text-sage-400 mb-2">{herb.scientific_name}</p>}

          <div class="flex flex-wrap gap-x-4 gap-y-1 text-sm text-gray-600 dark:text-earth-400">
            {herb.family && <span>Family: <span class="font-medium">{herb.family}</span></span>}
            {herb.genus && <span>Genus: <span class="font-medium italic">{herb.genus}</span></span>}
            {herb.species && <span>Species: <span class="font-medium italic">{herb.species}</span></span>}
            {herb.pinyin_name && <span>Pinyin: <span class="font-medium">{herb.pinyin_name}</span></span>}
            {herb.latin_name && herb.latin_name !== herb.scientific_name && <span>Latin: <span class="font-medium italic">{herb.latin_name}</span></span>}
          </div>

          {has(herb.synonyms) && (
            <p class="text-xs text-gray-500 dark:text-earth-500 mt-2">
              <span class="font-medium">Synonyms:</span>{" "}
              {(Array.isArray(herb.synonyms) ? herb.synonyms : [herb.synonyms]).map((s: any, i: number) => (
                <span class="italic">{i > 0 ? ", " : ""}{typeof s === "string" ? s : renderJsonItem(s)}</span>
              ))}
            </p>
          )}

          {/* Common names */}
          {herb.common_names?.length > 0 && (
            <div class="flex flex-wrap gap-2 mt-4">
              {herb.common_names.map((cn: any) => (
                <span class="text-sm px-3 py-1 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300">
                  {cn.name || cn} {cn.language ? `(${cn.language})` : ""}
                </span>
              ))}
            </div>
          )}
        </div>

        {/* Primary image */}
        {herb.images?.[0]?.file && (
          <figure class="w-full md:w-80">
            <div class="aspect-square rounded-xl overflow-hidden shadow-lg">
              <img
                src={imageUrl(herb.images[0].file, { width: 640, height: 640 })}
                alt={herb.images[0].caption || herb.title}
                class="w-full h-full object-cover"
              />
            </div>
            {(herb.images[0].caption || herb.images[0].credit || herb.images[0].license) && (
              <figcaption class="text-xs text-gray-500 dark:text-earth-400 mt-2 px-1">
                {herb.images[0].caption && <div>{herb.images[0].caption}</div>}
                {(herb.images[0].credit || herb.images[0].license) && (
                  <div class="italic">{[herb.images[0].credit, herb.images[0].license].filter(Boolean).join(" · ")}</div>
                )}
              </figcaption>
            )}
          </figure>
        )}
      </div>
    </div>
  </section>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="grid lg:grid-cols-3 gap-8">
      <!-- Main content -->
      <div class="lg:col-span-2 space-y-12">

        {/* TCM Properties */}
        {showTcm && (
          <section id="tcm" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4 flex items-center gap-2">☯ TCM Properties</h2>
            <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 space-y-4">
              {herb.tcm_category && <div><span class="text-sm font-medium text-gray-500 dark:text-earth-400">Category:</span> <span class="ml-2 font-medium">{herb.tcm_category}</span></div>}
              {herb.tcm_temperature && <div><span class="text-sm font-medium text-gray-500 dark:text-earth-400">Temperature:</span> <span class="ml-2 font-medium">{herb.tcm_temperature}</span></div>}
              {herb.tcm_taste?.length > 0 && <div><span class="text-sm font-medium text-gray-500 dark:text-earth-400">Taste:</span> <span class="ml-2">{herb.tcm_taste.join(", ")}</span></div>}
              {herb.tcm_meridians?.length > 0 && <div><span class="text-sm font-medium text-gray-500 dark:text-earth-400">Meridians:</span> <span class="ml-2">{herb.tcm_meridians.join(", ")}</span></div>}
              {herb.tcm_functions && <div><span class="text-sm font-medium text-gray-500 dark:text-earth-400">Functions:</span> <div class="mt-1 prose prose-sm dark:prose-invert" set:html={herb.tcm_functions} /></div>}
              {herb.tcm_category_tags?.length > 0 && (
                <div>
                  <span class="text-sm font-medium text-gray-500 dark:text-earth-400">Categories:</span>
                  <div class="flex flex-wrap gap-1 mt-1">
                    {herb.tcm_category_tags.map((t: any) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300">{t.tcm_categories_id?.name}</span>
                    ))}
                  </div>
                </div>
              )}
            </div>
          </section>
        )}

        {/* Western Properties */}
        {showWestern && (
          <section id="western" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Western Herbalism Properties</h2>
            <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 space-y-4">
              {herb.western_properties?.length > 0 && (
                <div>
                  <span class="text-sm font-medium text-gray-500 dark:text-earth-400">Actions:</span>
                  <div class="flex flex-wrap gap-1 mt-1">
                    {herb.western_properties.map((p: string) => (
                      <span class="text-xs px-2 py-0.5 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300 capitalize">{p}</span>
                    ))}
                  </div>
                </div>
              )}
              {herb.dosage_forms?.length > 0 && (
                <div>
                  <span class="text-sm font-medium text-gray-500 dark:text-earth-400">Available Forms:</span>
                  <span class="ml-2">{herb.dosage_forms.join(", ")}</span>
                </div>
              )}
            </div>
          </section>
        )}

        {/* Therapeutic Uses */}
        {herb.therapeutic_uses && (
          <section id="therapeutic" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Therapeutic Uses</h2>
            <div class="prose prose-earth dark:prose-invert max-w-none" set:html={herb.therapeutic_uses} />
          </section>
        )}

        {/* Pharmacological Effects */}
        {herb.pharmacological_effects && (
          <section id="pharmacology" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Pharmacological Effects</h2>
            <div class="prose prose-earth dark:prose-invert max-w-none" set:html={herb.pharmacological_effects} />
          </section>
        )}

        {/* Image Gallery (additional images beyond hero) */}
        {herb.images?.length > 1 && (
          <section id="gallery" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Gallery</h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
              {herb.images.slice(1).map((img: any) => img.file && (
                <figure class="bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 overflow-hidden">
                  <a href={imageUrl(img.file, { width: 1600 })} target="_blank" rel="noopener" class="block aspect-square overflow-hidden">
                    <img
                      src={imageUrl(img.file, { width: 400, height: 400 })}
                      alt={img.caption || `${herb.title} — ${img.image_type || "image"}`}
                      class="w-full h-full object-cover hover:scale-105 transition-transform duration-300"
                      loading="lazy"
                    />
                  </a>
                  {(img.image_type || img.caption || img.credit || img.license) && (
                    <figcaption class="p-3 text-xs text-gray-600 dark:text-earth-300 space-y-1">
                      {img.image_type && <div class="text-sage-700 dark:text-sage-400 font-medium">{img.image_type}</div>}
                      {img.caption && <div>{img.caption}</div>}
                      {(img.credit || img.license) && (
                        <div class="text-gray-400 dark:text-earth-500 italic">
                          {[img.credit, img.license].filter(Boolean).join(" · ")}
                        </div>
                      )}
                    </figcaption>
                  )}
                </figure>
              ))}
            </div>
          </section>
        )}

        {/* Botanical Description */}
        {showBotanical && (
          <section id="botanical" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Botanical Description</h2>
            <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6 space-y-4">
              {herb.botanical_description && <div class="prose prose-sm dark:prose-invert max-w-none" set:html={herb.botanical_description} />}
              {herb.habitat && (
                <div>
                  <span class="text-sm font-medium text-gray-500 dark:text-earth-400">Habitat:</span>
                  <p class="text-sm text-gray-700 dark:text-earth-200 mt-1 whitespace-pre-line">{herb.habitat}</p>
                </div>
              )}
              {herb.native_region?.length > 0 && (
                <div>
                  <span class="text-sm font-medium text-gray-500 dark:text-earth-400">Native Region:</span>
                  <span class="ml-2 text-sm">{(Array.isArray(herb.native_region) ? herb.native_region : [herb.native_region]).join(", ")}</span>
                </div>
              )}
              {herb.conservation_notes && (
                <div>
                  <span class="text-sm font-medium text-gray-500 dark:text-earth-400">Conservation Notes:</span>
                  <div class="mt-1 prose prose-sm dark:prose-invert" set:html={herb.conservation_notes} />
                </div>
              )}
            </div>
          </section>
        )}

        {/* Active Constituents (O2M) */}
        {herb.constituents?.length > 0 && (
          <section id="constituents" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Active Constituents</h2>
            <div class="space-y-3">
              {herb.constituents.map((c: any) => (
                <div class="bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 p-4">
                  <div class="flex items-center justify-between">
                    <h3 class="font-medium text-gray-900 dark:text-earth-100">{c.name}</h3>
                    {c.chemical_class && <span class="text-xs px-2 py-0.5 rounded-full bg-sage-100 dark:bg-earth-800 text-sage-700 dark:text-sage-300">{c.chemical_class}</span>}
                  </div>
                  {c.concentration && <p class="text-sm text-gray-500 dark:text-earth-400 mt-1">Concentration: {c.concentration}</p>}
                  {c.effects && <div class="text-sm text-gray-600 dark:text-earth-300 mt-2 prose prose-sm dark:prose-invert" set:html={c.effects} />}
                </div>
              ))}
            </div>
          </section>
        )}

        {/* Drug Interactions (O2M) */}
        {herb.drug_interactions?.length > 0 && (
          <section id="interactions" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4 flex items-center gap-2">⚠ Drug Interactions</h2>
            <div class="space-y-3">
              {herb.drug_interactions.map((di: any) => (
                <div class={`rounded-lg border p-4 ${di.severity === "Contraindicated" || di.interaction_type === "Major" ? "bg-red-50 dark:bg-red-950/20 border-red-200 dark:border-red-800" : "bg-amber-50 dark:bg-amber-950/20 border-amber-200 dark:border-amber-800"}`}>
                  <div class="flex items-center justify-between flex-wrap gap-2">
                    <h3 class="font-medium text-gray-900 dark:text-earth-100">{di.drug_name}</h3>
                    <div class="flex gap-1">
                      {di.interaction_type && <span class={`text-xs px-2 py-0.5 rounded-full font-medium ${di.interaction_type === "Major" ? "bg-red-100 text-red-700" : di.interaction_type === "Moderate" ? "bg-amber-100 text-amber-700" : "bg-green-100 text-green-700"}`}>{di.interaction_type}</span>}
                      {di.severity && <span class="text-xs px-2 py-0.5 rounded-full bg-gray-200 text-gray-700">{di.severity}</span>}
                      {di.evidence_level && <span class="text-xs px-2 py-0.5 rounded-full bg-blue-100 text-blue-700">Evidence: {di.evidence_level}</span>}
                    </div>
                  </div>
                  {di.mechanism && <div class="text-sm text-gray-600 dark:text-earth-300 mt-2 prose prose-sm dark:prose-invert" set:html={di.mechanism} />}
                  {di.clinical_note && <p class="text-sm text-gray-600 dark:text-earth-300 mt-2 whitespace-pre-line"><span class="font-medium">Clinical note:</span> {di.clinical_note}</p>}
                </div>
              ))}
            </div>
          </section>
        )}

        {/* Dosage (O2M) */}
        {herb.dosages?.length > 0 && (
          <section id="dosage" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Dosage</h2>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead><tr class="border-b border-gray-200 dark:border-earth-700">
                  <th class="text-left py-2 font-medium text-gray-500 dark:text-earth-400">Form</th>
                  <th class="text-left py-2 font-medium text-gray-500 dark:text-earth-400">Amount</th>
                  <th class="text-left py-2 font-medium text-gray-500 dark:text-earth-400">Frequency</th>
                  <th class="text-left py-2 font-medium text-gray-500 dark:text-earth-400">Duration</th>
                  <th class="text-left py-2 font-medium text-gray-500 dark:text-earth-400">Population</th>
                  <th class="text-left py-2 font-medium text-gray-500 dark:text-earth-400">Notes</th>
                </tr></thead>
                <tbody>
                  {herb.dosages.map((d: any) => (
                    <tr class="border-b border-gray-100 dark:border-earth-800 align-top">
                      <td class="py-2 text-gray-900 dark:text-earth-100">{d.form}</td>
                      <td class="py-2 text-gray-600 dark:text-earth-300">{d.amount || "—"}</td>
                      <td class="py-2 text-gray-600 dark:text-earth-300">{d.frequency || "—"}</td>
                      <td class="py-2 text-gray-600 dark:text-earth-300">{d.duration || "—"}</td>
                      <td class="py-2 text-gray-600 dark:text-earth-300">{d.population || "—"}</td>
                      <td class="py-2 text-gray-600 dark:text-earth-300">{d.notes ? <span set:html={d.notes} /> : "—"}</td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>
          </section>
        )}

        {/* Preparations (O2M) */}
        {herb.preparations?.length > 0 && (
          <section id="preparations" class="scroll-mt-24">
            <h2 class="font-serif text-2xl font-bold text-gray-900 dark:text-earth-100 mb-4">Preparation Methods</h2>
            <div class="space-y-4">
              {herb.preparations.map((p: any) => (
                <div class="bg-white dark:bg-earth-900 rounded-lg border border-gray-100 dark:border-earth-700 p-4">
                  <h3 class="font-medium text-gray-900 dark:text-earth-100">{p.method}</h3>
                  {p.parts_used?.length > 0 && (
                    <p class="text-xs text-gray-500 dark:text-earth-400 mt-1">Parts: {p.parts_used.join(", ")}</p>
                  )}
                  {p.instructions && <div class="text-sm text-gray-600 dark:text-earth-300 mt-2 prose prose-sm dark:prose-invert" set:html={p.instructions} />}
                  <div class="flex flex-wrap gap-4 mt-2 text-xs text-gray-500 dark:text-earth-400">
                    {p.time && <span>Time: {p.time}</span>}
                    {p.yield && <span>Yield: {p.yield}</span>}
