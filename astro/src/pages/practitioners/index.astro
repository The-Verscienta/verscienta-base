---
import ContentLayout from "@/layouts/ContentLayout.astro";
import { directus, readItems } from "@/lib/directus";

// Fetch practitioners and modalities server-side (avoids CORS)
let practitioners: any[] = [];
let modalities: any[] = [];
let fetchError = "";

const DIRECTUS_URL = import.meta.env.PUBLIC_DIRECTUS_URL || "http://localhost:8055";
const DIRECTUS_TOKEN = import.meta.env.DIRECTUS_TOKEN || (import.meta.env.DEV ? "" : "");

try {
  const url = `${DIRECTUS_URL}/items/practitioners?fields=*,modalities.modalities_id.id,modalities.modalities_id.title&sort=title&limit=500`;
  const headers: Record<string, string> = { "Content-Type": "application/json" };
  if (DIRECTUS_TOKEN) headers["Authorization"] = `Bearer ${DIRECTUS_TOKEN}`;

  const res = await fetch(url, { headers });
  if (!res.ok) {
    fetchError = `Directus returned ${res.status}: ${await res.text()}`;
    console.error(fetchError);
  } else {
    const json = await res.json();
    practitioners = json.data || [];
  }
} catch (e: any) {
  fetchError = `Fetch error: ${e?.message || e}`;
  console.error("Failed to load practitioners:", e);
}

try {
  modalities = await directus.request(readItems("modalities", { fields: ["id", "title"], sort: ["title"], limit: 100 })) as any;
} catch (e) { console.error("Failed to load modalities:", e); }

const practiceTypes = [
  { value: "tcm", label: "TCM" },
  { value: "western_herbalism", label: "Western Herbalism" },
  { value: "naturopathy", label: "Naturopathy" },
  { value: "ayurveda", label: "Ayurveda" },
  { value: "integrative", label: "Integrative" },
  { value: "other", label: "Other" },
];
---

<ContentLayout title="Find Practitioners — Verscienta Health" description="Search for holistic health practitioners near you by location, specialty, and practice type.">
  <!-- Hero -->
  <section class="bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <span class="text-sage-600 font-medium tracking-wide uppercase text-sm">Practitioner Directory</span>
      <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 dark:text-earth-100 mb-4 mt-2">Find a Practitioner</h1>
      <p class="text-lg text-gray-600 dark:text-earth-300 max-w-2xl">Search for holistic health practitioners by location, practice type, and specialty. Find the right provider for your needs.</p>
    </div>
  </section>

  {fetchError && (
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-4">
      <div class="bg-red-50 dark:bg-red-900/20 border border-red-200 dark:border-red-800 rounded-lg p-4 text-sm text-red-700 dark:text-red-300">
        <strong>Error:</strong> Unable to load practitioners. Please try again later.
      </div>
    </div>
  )}

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="lg:grid lg:grid-cols-[320px_1fr] lg:gap-8">

      <!-- Filters Sidebar -->
      <aside class="mb-8 lg:mb-0">
        <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 shadow-sm p-6 lg:sticky lg:top-20">
          <h2 class="font-semibold text-gray-900 dark:text-earth-100 mb-4 flex items-center gap-2">
            <svg class="w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" /></svg>
            Filters
          </h2>

          <form id="search-form" class="space-y-5">
            <!-- Location with autocomplete -->
            <div>
              <label for="location-input" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Location</label>
              <div class="relative" id="location-wrapper">
                <input
                  type="text"
                  id="location-input"
                  placeholder="City, state, or zip code"
                  autocomplete="off"
                  class="w-full pl-9 pr-8 py-2.5 text-sm border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500 placeholder-gray-400"
                />
                <svg class="w-4 h-4 text-gray-400 absolute left-3 top-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <div id="location-spinner" class="hidden absolute right-3 top-3">
                  <svg class="w-4 h-4 text-gray-400 animate-spin" fill="none" viewBox="0 0 24 24"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" opacity="0.3"/><path d="M12 2a10 10 0 0 1 10 10" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
                </div>
                <!-- Autocomplete dropdown -->
                <div id="location-dropdown" class="hidden absolute z-50 top-full left-0 right-0 mt-1 bg-white dark:bg-earth-800 border border-gray-200 dark:border-earth-600 rounded-lg shadow-lg max-h-60 overflow-y-auto">
                </div>
              </div>
              <button type="button" id="use-my-location" class="mt-1.5 text-xs text-sage-600 dark:text-sage-400 hover:underline flex items-center gap-1">
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" /></svg>
                Use my location
              </button>
            </div>

            <!-- Distance -->
            <div>
              <label for="distance-select" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Distance</label>
              <select id="distance-select" class="w-full px-3 py-2.5 text-sm border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500">
                <option value="">Any distance</option>
                <option value="10">Within 10 miles</option>
                <option value="25">Within 25 miles</option>
                <option value="50" selected>Within 50 miles</option>
                <option value="100">Within 100 miles</option>
                <option value="250">Within 250 miles</option>
              </select>
            </div>

            <!-- Practice Type -->
            <div>
              <label class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-2">Practice Type</label>
              <div class="space-y-2">
                {practiceTypes.map((pt) => (
                  <label class="flex items-center gap-2 cursor-pointer">
                    <input type="checkbox" name="practice_type" value={pt.value} class="rounded border-gray-300 dark:border-earth-600 text-sage-600 focus:ring-sage-500 dark:bg-earth-800" />
                    <span class="text-sm text-gray-700 dark:text-earth-300">{pt.label}</span>
                  </label>
                ))}
              </div>
            </div>

            <!-- Modality / Specialty -->
            {modalities.length > 0 && (
              <div>
                <label for="modality-select" class="block text-sm font-medium text-gray-700 dark:text-earth-300 mb-1">Specialty</label>
                <select id="modality-select" class="w-full px-3 py-2.5 text-sm border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-900 dark:text-earth-100 focus:ring-2 focus:ring-sage-500">
                  <option value="">All specialties</option>
                  {modalities.map((m: any) => (
                    <option value={m.id}>{m.title}</option>
                  ))}
                </select>
              </div>
            )}

            <!-- Search button -->
            <button
              type="submit"
              class="w-full px-4 py-2.5 bg-gradient-to-r from-sage-600 to-earth-600 text-white text-sm font-medium rounded-lg shadow hover:shadow-md transition-all"
            >
              Search Practitioners
            </button>

            <button type="button" id="clear-filters" class="w-full px-4 py-2 text-sm text-gray-500 dark:text-earth-400 hover:text-gray-700 dark:hover:text-earth-200 transition">
              Clear all filters
            </button>
          </form>
        </div>
      </aside>

      <!-- Results Area -->
      <div>
        <!-- Status bar -->
        <div class="flex items-center justify-between mb-4">
          <p id="results-count" class="text-sm text-gray-600 dark:text-earth-400">Loading practitioners...</p>
          <select id="sort-select" class="text-sm border border-gray-200 dark:border-earth-600 rounded-lg bg-white dark:bg-earth-800 text-gray-700 dark:text-earth-300 px-3 py-1.5 focus:ring-2 focus:ring-sage-500">
            <option value="name">Sort by name</option>
            <option value="distance">Sort by distance</option>
            <option value="type">Sort by type</option>
          </select>
        </div>

        <!-- Results grid -->
        <div id="results-grid" class="grid sm:grid-cols-2 gap-4">
          <!-- Populated by JS -->
        </div>

        <!-- Empty state -->
        <div id="results-empty" class="hidden text-center py-16">
          <svg class="w-16 h-16 mx-auto text-gray-300 dark:text-earth-600 mb-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          <h3 class="text-lg font-semibold text-gray-700 dark:text-earth-300 mb-2">No practitioners found</h3>
          <p class="text-gray-500 dark:text-earth-400 max-w-md mx-auto">Try widening your search area or removing some filters.</p>
        </div>

        <!-- Loading state -->
        <div id="results-loading" class="text-center py-16">
          <div class="inline-block w-8 h-8 border-4 border-sage-200 border-t-sage-600 rounded-full animate-spin"></div>
          <p class="mt-3 text-sm text-gray-500 dark:text-earth-400">Searching...</p>
        </div>
      </div>
    </div>
  </div>

  <!-- Server-side data embedded in DOM attribute (CSP-safe, no script execution needed) -->
  <div id="practitioners-data" hidden data-json={JSON.stringify(practitioners)}></div>

  <script>
    const grid = document.getElementById('results-grid')!;
    const emptyState = document.getElementById('results-empty')!;
    const loadingState = document.getElementById('results-loading')!;
    const countEl = document.getElementById('results-count')!;
    const sortSelect = document.getElementById('sort-select') as HTMLSelectElement;
    const locationInput = document.getElementById('location-input') as HTMLInputElement;
    const distanceSelect = document.getElementById('distance-select') as HTMLSelectElement;
    const modalitySelect = document.getElementById('modality-select') as HTMLSelectElement;

    let allPractitioners: any[] = [];
    try {
      const raw = document.getElementById('practitioners-data')?.getAttribute('data-json');
      if (raw) {
        allPractitioners = JSON.parse(raw);
      }
    } catch (e) {
      console.error('Failed to parse practitioners data:', e);
    }
    let userLat: number | null = null;
    let userLon: number | null = null;

    // ── Haversine distance (miles) ──────────────────────────────────
    function haversine(lat1: number, lon1: number, lat2: number, lon2: number): number {
      const R = 3959; // Earth radius in miles
      const dLat = (lat2 - lat1) * Math.PI / 180;
      const dLon = (lon2 - lon1) * Math.PI / 180;
      const a = Math.sin(dLat / 2) ** 2 +
        Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) *
        Math.sin(dLon / 2) ** 2;
      return R * 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1 - a));
    }

    // ── Geocode location text via server-side proxy ───────────────
    async function geocode(query: string): Promise<{ lat: number; lon: number } | null> {
      try {
        const res = await fetch(`/api/geocode?text=${encodeURIComponent(query)}`);
        const data = await res.json();
        if (data.result) {
          return { lat: data.result.lat, lon: data.result.lon };
        }
      } catch {}
      return null;
    }

    // ── Location autocomplete ──────────────────────────────────────
    const locationDropdown = document.getElementById('location-dropdown')!;
    const locationSpinner = document.getElementById('location-spinner')!;
    let acDebounce: ReturnType<typeof setTimeout> | null = null;
    let acSelectedIdx = -1;
    let acResults: any[] = [];

    async function fetchAutocomplete(text: string) {
      if (text.length < 3) {
        hideAutocomplete();
        return;
      }
      locationSpinner.classList.remove('hidden');
      try {
        const res = await fetch(`/api/geocode-autocomplete?text=${encodeURIComponent(text)}&limit=5`);
        const data = await res.json();
        acResults = data.results || [];
        if (acResults.length > 0) {
          renderAutocomplete();
        } else {
          hideAutocomplete();
        }
      } catch {
        hideAutocomplete();
      } finally {
        locationSpinner.classList.add('hidden');
      }
    }

    function renderAutocomplete() {
      locationDropdown.innerHTML = acResults.map((r, i) => {
        const main = r.city && r.state ? `${r.city}, ${r.state}` : r.formatted;
        const detail = r.city && r.state && r.formatted !== `${r.city}, ${r.state}` ? r.formatted : '';
        return `
          <div class="ac-item px-3 py-2.5 cursor-pointer text-sm transition-colors
            ${i === acSelectedIdx ? 'bg-sage-50 dark:bg-earth-700' : 'hover:bg-gray-50 dark:hover:bg-earth-700'}
            ${i < acResults.length - 1 ? 'border-b border-gray-100 dark:border-earth-600' : ''}"
            data-index="${i}">
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-gray-400 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <div class="min-w-0">
                <div class="font-medium text-gray-900 dark:text-earth-100 truncate">${main}</div>
                ${detail ? `<div class="text-xs text-gray-500 dark:text-earth-400 truncate">${detail}</div>` : ''}
              </div>
            </div>
          </div>
        `;
      }).join('');

      locationDropdown.classList.remove('hidden');

      // Attach click handlers
      locationDropdown.querySelectorAll('.ac-item').forEach(el => {
        el.addEventListener('mousedown', (e) => {
          e.preventDefault(); // prevent blur before click registers
          const idx = parseInt((el as HTMLElement).dataset.index || '0');
          selectAutocomplete(idx);
        });
      });
    }

    function selectAutocomplete(idx: number) {
      const result = acResults[idx];
      if (!result) return;

      locationInput.value = result.formatted;
      userLat = result.lat;
      userLon = result.lon;
      sortSelect.value = 'distance';
      hideAutocomplete();
      filterAndRender();
    }

    function hideAutocomplete() {
      locationDropdown.classList.add('hidden');
      locationDropdown.innerHTML = '';
      acSelectedIdx = -1;
      acResults = [];
    }

    // Wire up location input for autocomplete
    locationInput.addEventListener('input', () => {
      // Reset coords when user edits the location text — will re-geocode on submit if needed
      userLat = null;
      userLon = null;

      const val = locationInput.value.trim();
      if (acDebounce) clearTimeout(acDebounce);
      if (val.length < 3) {
        hideAutocomplete();
        return;
      }
      acDebounce = setTimeout(() => fetchAutocomplete(val), 250);
    });

    locationInput.addEventListener('keydown', (e) => {
      if (!acResults.length) return;

      if (e.key === 'ArrowDown') {
        e.preventDefault();
        acSelectedIdx = Math.min(acSelectedIdx + 1, acResults.length - 1);
        renderAutocomplete();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        acSelectedIdx = Math.max(acSelectedIdx - 1, -1);
        renderAutocomplete();
      } else if (e.key === 'Enter' && acSelectedIdx >= 0) {
        e.preventDefault();
        e.stopPropagation();
        selectAutocomplete(acSelectedIdx);
      } else if (e.key === 'Escape') {
        hideAutocomplete();
      }
    });

    locationInput.addEventListener('blur', () => {
      // Small delay so click on dropdown item registers before hide
      setTimeout(() => hideAutocomplete(), 150);
    });

    // ── Practice type label ─────────────────────────────────────────
    const TYPE_LABELS: Record<string, string> = {
      tcm: 'TCM',
      western_herbalism: 'Western Herbalism',
      naturopathy: 'Naturopathy',
      ayurveda: 'Ayurveda',
      integrative: 'Integrative',
      other: 'Other',
    };

    const TYPE_COLORS: Record<string, string> = {
      tcm: 'bg-red-100 text-red-700 dark:bg-red-900/30 dark:text-red-300',
      western_herbalism: 'bg-green-100 text-green-700 dark:bg-green-900/30 dark:text-green-300',
      naturopathy: 'bg-blue-100 text-blue-700 dark:bg-blue-900/30 dark:text-blue-300',
      ayurveda: 'bg-orange-100 text-orange-700 dark:bg-orange-900/30 dark:text-orange-300',
      integrative: 'bg-purple-100 text-purple-700 dark:bg-purple-900/30 dark:text-purple-300',
      other: 'bg-gray-100 text-gray-700 dark:bg-gray-700 dark:text-gray-300',
    };

    // ── Build display address from structured or legacy fields ─────
    function formatAddress(p: any): string {
      const parts = [];
      if (p.street_address) parts.push(p.street_address);
      if (p.suite_apt) parts.push(p.suite_apt);
      if (p.city && p.state) {
        parts.push(`${p.city}, ${p.state}`);
      } else if (p.city) {
        parts.push(p.city);
      } else if (p.state) {
        parts.push(p.state);
      }
      if (p.zip_code) parts.push(p.zip_code);
      if (parts.length > 0) return parts.join(', ');
      return p.address || '';
    }

    // ── Render a practitioner card ──────────────────────────────────
    function renderCard(p: any): string {
      const typeLabel = TYPE_LABELS[p.practice_type] || p.practice_type || '';
      const typeColor = TYPE_COLORS[p.practice_type] || TYPE_COLORS.other;
      const modList = (p.modalities || [])
        .map((m: any) => m.modalities_id?.title)
        .filter(Boolean)
        .join(', ');
      const distStr = p._distance != null
        ? `<span class="text-xs text-sage-600 dark:text-sage-400 font-medium">${Math.round(p._distance)} mi</span>`
        : '';
      const bioSnippet = p.bio
        ? p.bio.replace(/<[^>]*>/g, '').slice(0, 120) + (p.bio.length > 120 ? '...' : '')
        : '';
      const displayAddress = formatAddress(p);

      return `
        <a href="/practitioners/${p.slug || p.id}" class="group bg-white dark:bg-earth-900 rounded-xl shadow-sm border border-gray-100 dark:border-earth-700 hover:shadow-lg hover:border-sage-300 dark:hover:border-sage-700 transition-all p-5">
          <div class="flex items-start justify-between mb-2">
            <h3 class="font-serif text-lg font-bold text-gray-900 dark:text-earth-100 group-hover:text-sage-600 transition-colors">${p.title}</h3>
            ${distStr}
          </div>
          <div class="flex flex-wrap gap-1.5 mb-3">
            ${typeLabel ? `<span class="text-xs px-2 py-0.5 rounded-full ${typeColor}">${typeLabel}</span>` : ''}
            ${modList ? `<span class="text-xs px-2 py-0.5 rounded-full bg-sage-100 text-sage-700 dark:bg-sage-900/30 dark:text-sage-300">${modList}</span>` : ''}
          </div>
          ${displayAddress ? `
            <p class="text-sm text-gray-500 dark:text-earth-400 mb-2 flex items-center gap-1.5">
              <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a2 2 0 01-2.828 0l-4.243-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              ${displayAddress}
            </p>
          ` : ''}
          ${bioSnippet ? `<p class="text-sm text-gray-600 dark:text-earth-400 line-clamp-2">${bioSnippet}</p>` : ''}
        </a>
      `;
    }

    // ── Filter & render results ─────────────────────────────────────
    function filterAndRender() {
      const checkedTypes = Array.from(document.querySelectorAll<HTMLInputElement>('input[name="practice_type"]:checked')).map(el => el.value);
      const selectedModality = modalitySelect?.value || '';
      const maxDistance = distanceSelect.value ? parseInt(distanceSelect.value) : null;

      let filtered = allPractitioners.map(p => {
        const copy = { ...p };
        if (userLat != null && userLon != null && p.latitude && p.longitude) {
          copy._distance = haversine(userLat, userLon, parseFloat(p.latitude), parseFloat(p.longitude));
        } else {
          copy._distance = null;
        }
        return copy;
      });

      // Filter by distance (practitioners without coordinates are always included)
      if (maxDistance && userLat != null) {
        filtered = filtered.filter(p => p._distance == null || p._distance <= maxDistance);
      }

      // Filter by practice type
      if (checkedTypes.length > 0) {
        filtered = filtered.filter(p => checkedTypes.includes(p.practice_type));
      }

      // Filter by modality
      if (selectedModality) {
        filtered = filtered.filter(p =>
          (p.modalities || []).some((m: any) => String(m.modalities_id?.id || m.modalities_id) === selectedModality)
        );
      }

      // Sort
      const sortBy = sortSelect.value;
      if (sortBy === 'distance' && userLat != null) {
        filtered.sort((a, b) => (a._distance ?? 99999) - (b._distance ?? 99999));
      } else if (sortBy === 'type') {
        filtered.sort((a, b) => (a.practice_type || '').localeCompare(b.practice_type || ''));
      } else {
        filtered.sort((a, b) => (a.title || '').localeCompare(b.title || ''));
      }

      // Render
      loadingState.classList.add('hidden');
      if (filtered.length === 0) {
        grid.innerHTML = '';
        emptyState.classList.remove('hidden');
        countEl.textContent = 'No practitioners found';
      } else {
        emptyState.classList.add('hidden');
        grid.innerHTML = filtered.map(renderCard).join('');
        const suffix = userLat != null ? ' near you' : '';
        countEl.textContent = `${filtered.length} practitioner${filtered.length === 1 ? '' : 's'} found${suffix}`;
      }
    }

    // ── Practitioners loaded server-side, no fetch needed ──────────

    // ── Event listeners ─────────────────────────────────────────────
    document.getElementById('search-form')?.addEventListener('submit', async (e) => {
      e.preventDefault();
      hideAutocomplete();
      loadingState.classList.remove('hidden');
      grid.innerHTML = '';
      emptyState.classList.add('hidden');

      const locationQuery = locationInput.value.trim();
      if (locationQuery && userLat == null) {
        // Only geocode if user typed manually without picking an autocomplete suggestion
        const coords = await geocode(locationQuery);
        if (coords) {
          userLat = coords.lat;
          userLon = coords.lon;
          sortSelect.value = 'distance';
        } else {
          countEl.textContent = `Could not find location "${locationQuery}". Showing all results.`;
        }
      }

      filterAndRender();
    });

    // Use my location
    document.getElementById('use-my-location')?.addEventListener('click', () => {
      if (!navigator.geolocation) {
        countEl.textContent = 'Geolocation is not supported by your browser.';
        return;
      }

      locationInput.value = 'Detecting location...';
      navigator.geolocation.getCurrentPosition(
        (pos) => {
          userLat = pos.coords.latitude;
          userLon = pos.coords.longitude;
          locationInput.value = `${userLat.toFixed(4)}, ${userLon.toFixed(4)}`;
          sortSelect.value = 'distance';
          filterAndRender();
        },
        () => {
          locationInput.value = '';
          countEl.textContent = 'Location access denied. Please type a location.';
        }
      );
    });

    // Sort change
    sortSelect.addEventListener('change', filterAndRender);

    // Clear filters
    document.getElementById('clear-filters')?.addEventListener('click', () => {
      locationInput.value = '';
      distanceSelect.value = '';
      if (modalitySelect) modalitySelect.value = '';
      document.querySelectorAll<HTMLInputElement>('input[name="practice_type"]:checked').forEach(el => el.checked = false);
      userLat = null;
      userLon = null;
      sortSelect.value = 'name';
      filterAndRender();
    });

    // Initial render (data already loaded server-side)
    filterAndRender();
  </script>
</ContentLayout>
