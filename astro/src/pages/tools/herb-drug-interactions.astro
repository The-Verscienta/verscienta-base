---
/**
 * Herb-Drug Interaction Checker — Astro shell with React island.
 */
import ContentLayout from "@/layouts/ContentLayout.astro";
import HerbDrugChecker from "@/components/HerbDrugChecker";
---

<ContentLayout title="Herb-Drug Interaction Checker — Verscienta Health" description="Check potential interactions between herbs and pharmaceutical medications. AI-powered clinical analysis with mechanism explanations.">
  <section class="bg-gradient-to-br from-earth-50 via-sage-50/50 to-cream-100 dark:from-earth-950 dark:via-earth-900/50 dark:to-earth-950 border-b border-sage-200/50 dark:border-earth-700">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 md:py-16">
      <div class="max-w-2xl">
        <div class="flex items-center gap-3 mb-4">
          <div class="w-10 h-10 rounded-lg bg-gradient-to-br from-sage-500 to-earth-600 flex items-center justify-center shadow-lg"><span class="text-xl">💊</span></div>
          <span class="text-sage-600 font-medium tracking-wide uppercase text-sm">Safety Tool</span>
        </div>
        <h1 class="font-serif text-4xl md:text-5xl font-bold text-gray-900 dark:text-earth-100 mb-4">Drug Interaction Checker</h1>
        <p class="text-lg text-gray-600 dark:text-earth-300">Enter your medications and any herbs you're taking. Our AI clinical pharmacologist analyzes pharmacokinetic and pharmacodynamic interactions, flags severity, and explains mechanisms.</p>
      </div>
    </div>
  </section>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="bg-amber-50 dark:bg-earth-900 border border-amber-200 dark:border-earth-700 rounded-xl p-4 mb-8">
      <p class="text-sm text-amber-700 dark:text-amber-400"><strong>Important:</strong> This tool provides clinical guidance to inform your conversations with healthcare providers. It does not replace professional medical advice. Always consult your doctor or pharmacist before combining herbs with prescription medications, especially for conditions like blood thinning, diabetes, blood pressure, or psychiatric medications.</p>
    </div>

    <div class="bg-white dark:bg-earth-900 rounded-xl border border-gray-100 dark:border-earth-700 p-6">
      <HerbDrugChecker client:load />
    </div>
  </div>
</ContentLayout>
