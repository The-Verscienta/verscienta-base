---
/**
 * Section — reusable content section with variant styling.
 * Ported from the Section component in DesignSystem.tsx.
 */
interface Props {
  id?: string;
  title?: string;
  subtitle?: string;
  icon?: string;
  variant?: "default" | "warning" | "tcm" | "cultural" | "feature" | "card" | "botanical";
  class?: string;
}

const { id, title, subtitle, icon, variant = "default", class: className = "" } = Astro.props;

const variantStyles: Record<string, { container: string; title: string; subtitle: string }> = {
  default: {
    container: "bg-surface border-default",
    title: "text-primary",
    subtitle: "text-secondary",
  },
  warning: {
    container: "bg-gradient-to-br from-warm-50 to-gold-50 dark:from-warm-950/40 dark:to-gold-950/30 border-warm-200 dark:border-warm-800",
    title: "text-warm-800 dark:text-warm-200",
    subtitle: "text-warm-700 dark:text-warm-300",
  },
  tcm: {
    container: "bg-gradient-to-br from-tcm-50 via-gold-50/60 to-warm-50/40 dark:from-tcm-950/40 dark:via-gold-950/30 dark:to-warm-950/30 border-tcm-200 dark:border-tcm-800",
    title: "text-tcm-800 dark:text-tcm-200",
    subtitle: "text-tcm-700 dark:text-tcm-300",
  },
  cultural: {
    container: "bg-gradient-to-br from-sage-50 to-earth-50 dark:from-sage-950/40 dark:to-earth-950/40 border-sage-300 dark:border-sage-800",
    title: "text-primary",
    subtitle: "text-secondary",
  },
  feature: {
    container: "bg-gradient-to-br from-earth-50 to-sage-50 dark:from-earth-900 dark:to-sage-900/50 border-earth-200 dark:border-earth-700",
    title: "text-primary",
    subtitle: "text-secondary",
  },
  card: {
    container: "bg-surface-elevated border-subtle shadow-sm",
    title: "text-primary",
    subtitle: "text-secondary",
  },
  botanical: {
    container: "bg-gradient-to-br from-cream-50 to-sage-50/30 dark:from-earth-900 dark:to-sage-950/30 border-sage-200 dark:border-sage-800",
    title: "text-primary",
    subtitle: "text-secondary",
  },
};

const styles = variantStyles[variant];
---

<section id={id} class={`border rounded-2xl p-6 md:p-8 scroll-mt-24 ${styles.container} ${className}`}>
  {title && (
    <div class="mb-6">
      <h2 class={`font-serif text-2xl md:text-3xl font-bold flex items-center gap-3 ${styles.title}`}>
        {icon && <span class="text-2xl">{icon}</span>}
        {title}
      </h2>
      {subtitle && (
        <p class={`text-lg mt-2 ${styles.subtitle}`}>{subtitle}</p>
      )}
    </div>
  )}
  <slot />
</section>
