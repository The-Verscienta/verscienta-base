---
/**
 * DisclaimerBox — amber warning box for medical disclaimers.
 */
interface Props {
  title?: string;
  class?: string;
}

const { title = "Important Disclaimer", class: className = "" } = Astro.props;
---

<div class={`bg-gradient-to-br from-amber-50 to-yellow-50 dark:from-amber-950/20 dark:to-yellow-950/10 border border-amber-200 dark:border-amber-800 rounded-2xl p-6 md:p-8 shadow-sm ${className}`}>
  <div class="flex gap-4">
    <div class="w-12 h-12 bg-amber-100 dark:bg-amber-900/40 rounded-xl flex items-center justify-center flex-shrink-0">
      <svg class="w-6 h-6 text-amber-600 dark:text-amber-400" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
      </svg>
    </div>
    <div>
      <h3 class="font-serif text-lg font-bold text-amber-900 dark:text-amber-300 mb-2">{title}</h3>
      <div class="text-sm text-amber-800 dark:text-amber-400 leading-relaxed">
        <slot />
      </div>
    </div>
  </div>
</div>
