---
/**
 * Tag — pill-shaped label with brand & semantic variants.
 *
 * Variants are limited to the brand palette + semantic status to keep
 * the design consistent. Use `neutral` for non-categorical tags.
 */
type Variant =
  | "earth" | "sage" | "tcm" | "gold" | "warm" | "cream"
  | "success" | "warning" | "danger" | "info"
  | "neutral";

interface Props {
  variant?: Variant;
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "sage", size = "sm", class: className = "" } = Astro.props;

/* Dark-mode rule: all colored variants use `dark:bg-{palette}-900/40`
 * (translucent) so the dark surface tints through consistently. Borders
 * and text use solid stops for legibility. Status variants use the
 * semantic --status-*-bg variables (already alpha-baked in dark mode). */
const variantStyles: Record<Variant, string> = {
  earth:   "bg-earth-100   text-earth-800  border-earth-200  dark:bg-earth-900/40   dark:text-earth-200  dark:border-earth-700",
  sage:    "bg-sage-100    text-sage-800   border-sage-200   dark:bg-sage-900/40    dark:text-sage-200   dark:border-sage-700",
  tcm:     "bg-tcm-100     text-tcm-800    border-tcm-200    dark:bg-tcm-900/40     dark:text-tcm-200    dark:border-tcm-800",
  gold:    "bg-gold-100    text-gold-800   border-gold-200   dark:bg-gold-900/40    dark:text-gold-200   dark:border-gold-700",
  warm:    "bg-warm-100    text-warm-800   border-warm-200   dark:bg-warm-900/40    dark:text-warm-200   dark:border-warm-800",
  cream:   "bg-cream-100   text-earth-800  border-cream-300  dark:bg-earth-900      dark:text-earth-100  dark:border-earth-700",

  success: "bg-success text-success border-transparent",
  warning: "bg-warning text-warning border-transparent",
  danger:  "bg-danger  text-danger  border-transparent",
  info:    "bg-info    text-info    border-transparent",

  neutral: "bg-surface-muted text-secondary border-default",
};

const sizeStyles: Record<NonNullable<Props["size"]>, string> = {
  sm: "px-2 py-0.5 text-xs",
  md: "px-3 py-1.5 text-sm",
  lg: "px-4 py-2 text-base",
};
---

<span class={`inline-flex items-center font-medium rounded-full border transition-all hover:scale-105 motion-reduce:hover:scale-100 ${variantStyles[variant]} ${sizeStyles[size]} ${className}`}>
  <slot />
</span>
