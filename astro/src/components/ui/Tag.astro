---
/**
 * Tag — pill-shaped label with color variants.
 * Ported from the Tag component in DesignSystem.tsx.
 */
interface Props {
  variant?: "sage" | "earth" | "amber" | "blue" | "purple" | "red" | "cyan" | "orange" | "green" | "gray" | "gold" | "warm" | "muted";
  size?: "sm" | "md" | "lg";
  class?: string;
}

const { variant = "sage", size = "sm", class: className = "" } = Astro.props;

const variantStyles: Record<string, string> = {
  sage: "bg-sage-100 text-sage-800 border-sage-200 dark:bg-sage-900/40 dark:text-sage-200 dark:border-sage-700",
  earth: "bg-earth-100 text-earth-800 border-earth-200 dark:bg-earth-800 dark:text-earth-200 dark:border-earth-700",
  amber: "bg-amber-100 text-amber-800 border-amber-200 dark:bg-amber-900/40 dark:text-amber-200 dark:border-amber-700",
  blue: "bg-blue-100 text-blue-800 border-blue-200 dark:bg-blue-900/40 dark:text-blue-200 dark:border-blue-700",
  purple: "bg-purple-100 text-purple-800 border-purple-200 dark:bg-purple-900/40 dark:text-purple-200 dark:border-purple-700",
  red: "bg-red-100 text-red-800 border-red-200 dark:bg-red-900/40 dark:text-red-200 dark:border-red-700",
  cyan: "bg-cyan-100 text-cyan-800 border-cyan-200 dark:bg-cyan-900/40 dark:text-cyan-200 dark:border-cyan-700",
  orange: "bg-orange-100 text-orange-800 border-orange-200 dark:bg-orange-900/40 dark:text-orange-200 dark:border-orange-700",
  green: "bg-green-100 text-green-800 border-green-200 dark:bg-green-900/40 dark:text-green-200 dark:border-green-700",
  gray: "bg-gray-100 text-gray-700 border-gray-200 dark:bg-gray-800 dark:text-gray-300 dark:border-gray-700",
  gold: "bg-gold-100 text-gold-800 border-gold-200 dark:bg-gold-900/40 dark:text-gold-200 dark:border-gold-700",
  warm: "bg-warm-100 text-warm-800 border-warm-200 dark:bg-warm-900/40 dark:text-warm-200 dark:border-warm-700",
  muted: "bg-gray-50 text-gray-500 border-gray-100 dark:bg-earth-800 dark:text-earth-400 dark:border-earth-700",
};

const sizeStyles: Record<string, string> = {
  sm: "px-2 py-0.5 text-xs",
  md: "px-3 py-1.5 text-sm",
  lg: "px-4 py-2 text-base",
};
---

<span class={`inline-flex items-center font-medium rounded-full border transition-all hover:scale-105 ${variantStyles[variant]} ${sizeStyles[size]} ${className}`}>
  <slot />
</span>
