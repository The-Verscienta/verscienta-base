---
/**
 * Content Layout — wraps pages with header and footer.
 * Use this for all standard pages.
 */
import RootLayout from "./RootLayout.astro";

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const { title, description, ogImage } = Astro.props;
---

<RootLayout title={title} description={description} ogImage={ogImage}>
  <!-- Header (React island for interactivity) -->
  <Fragment slot="header">
    <header class="sticky top-0 z-50 bg-gradient-to-r from-earth-800 via-earth-700 to-sage-800 dark:from-earth-900 dark:via-earth-850 dark:to-sage-900 shadow-lg shadow-earth-900/20">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <!-- Logo -->
          <a href="/" class="flex items-center gap-2.5 flex-shrink-0">
            <svg viewBox="0 0 40 40" class="w-9 h-9" fill="none">
              <defs>
                <linearGradient id="lg1" x1="0%" y1="0%" x2="100%" y2="100%">
                  <stop offset="0%" stop-color="#a9c2b1" />
                  <stop offset="50%" stop-color="#6b9279" />
                  <stop offset="100%" stop-color="#426650" />
                </linearGradient>
                <linearGradient id="lg2" x1="0%" y1="100%" x2="100%" y2="0%">
                  <stop offset="0%" stop-color="#d4a574" />
                  <stop offset="100%" stop-color="#e0b589" />
                </linearGradient>
              </defs>
              <path d="M20 4c-3 10-12 16-12 24a12 12 0 0024 0c0-8-9-14-12-24z" fill="url(#lg1)" />
              <path d="M20 10v20M16 16c2 2 4 6 4 10M24 16c-2 2-4 6-4 10" stroke="white" stroke-width="1.5" stroke-linecap="round" stroke-opacity="0.6" />
              <circle cx="20" cy="34" r="2" fill="url(#lg2)" />
            </svg>
            <div class="hidden sm:block">
              <span class="font-serif text-lg font-bold text-white leading-none">Verscienta</span>
              <span class="block text-[10px] text-earth-300 tracking-wider uppercase">Holistic Health</span>
            </div>
          </a>

          <!-- Primary nav — highlighted tools + content links -->
          <nav class="hidden lg:flex items-center gap-1">
            <!-- Highlighted tools -->
            <a href="/symptom-checker" class="px-3 py-1.5 text-sm font-medium bg-sage-600/80 hover:bg-sage-600 text-white rounded-lg transition">Symptom Checker</a>
            <a href="/tools/herb-drug-interactions" class="px-3 py-1.5 text-sm font-medium bg-earth-600/60 hover:bg-earth-600 text-white rounded-lg transition">Drug Checker</a>

            <span class="w-px h-5 bg-white/20 mx-2"></span>

            <!-- Content links -->
            <a href="/herbs" class="px-2.5 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Herbs</a>
            <a href="/formulas" class="px-2.5 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Formulas</a>
            <a href="/points" class="px-2.5 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Points</a>
            <a href="/patterns" class="px-2.5 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Patterns</a>
            <a href="/concepts" class="px-2.5 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Concepts</a>
            <a href="/modalities" class="px-2.5 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Modalities</a>
            <a href="/conditions" class="px-2.5 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Conditions</a>

            <span class="w-px h-5 bg-white/20 mx-2"></span>

            <!-- Utility links -->
            <a href="/search" class="p-2 text-earth-300 hover:text-white hover:bg-white/10 rounded-lg transition" title="Search">
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
            </a>
            <!-- Auth: shown when NOT logged in -->
            <a href="/login" id="nav-login" class="px-3 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">Login</a>

            <!-- Auth: shown when logged in -->
            <div id="nav-user-menu" class="hidden relative">
              <button id="nav-user-btn" class="flex items-center gap-2 px-3 py-1.5 text-sm text-earth-200 hover:text-white hover:bg-white/10 rounded-lg transition">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" /></svg>
                <span id="nav-user-name"></span>
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
              </button>
              <div id="nav-user-dropdown" class="hidden absolute right-0 mt-1 w-48 bg-white dark:bg-earth-800 rounded-lg shadow-lg border border-gray-200 dark:border-earth-700 py-1 z-50">
                <a href="/dashboard" class="block px-4 py-2 text-sm text-gray-700 dark:text-earth-200 hover:bg-gray-100 dark:hover:bg-earth-700">Dashboard</a>
                <a href="/profile" class="block px-4 py-2 text-sm text-gray-700 dark:text-earth-200 hover:bg-gray-100 dark:hover:bg-earth-700">Profile</a>
                <div class="h-px bg-gray-200 dark:bg-earth-700 my-1"></div>
                <button id="nav-logout-btn" class="w-full text-left px-4 py-2 text-sm text-red-600 dark:text-red-400 hover:bg-gray-100 dark:hover:bg-earth-700">Sign Out</button>
              </div>
            </div>
          </nav>

          <!-- Mobile menu button -->
          <button id="mobile-nav-toggle" class="lg:hidden p-2 text-earth-200 hover:text-white" aria-label="Menu">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" /></svg>
          </button>
        </div>

        <!-- Mobile nav -->
        <nav id="mobile-nav" class="hidden lg:hidden pb-4 border-t border-white/10 mt-2 pt-3">
          <div class="flex flex-col gap-1">
            <a href="/symptom-checker" class="px-3 py-2 text-sm font-medium text-white bg-sage-600/50 rounded-lg">Symptom Checker</a>
            <a href="/tools/herb-drug-interactions" class="px-3 py-2 text-sm font-medium text-white bg-earth-600/40 rounded-lg">Drug Checker</a>
            <div class="h-px bg-white/10 my-1"></div>
            <a href="/herbs" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Herbs</a>
            <a href="/formulas" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Formulas</a>
            <a href="/points" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Points</a>
            <a href="/patterns" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Patterns</a>
            <a href="/concepts" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Concepts</a>
            <a href="/modalities" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Modalities</a>
            <a href="/conditions" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Conditions</a>
            <div class="h-px bg-white/10 my-1"></div>
            <a href="/practitioners" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Find Practitioners</a>
            <a href="/search" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Search</a>
            <!-- Auth: shown when NOT logged in -->
            <a href="/login" id="mobile-nav-login" class="px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Login</a>
            <!-- Auth: shown when logged in -->
            <a href="/dashboard" id="mobile-nav-dashboard" class="hidden px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Dashboard</a>
            <a href="/profile" id="mobile-nav-profile" class="hidden px-3 py-2 text-sm text-earth-200 hover:bg-white/10 rounded-lg">Profile</a>
            <button id="mobile-nav-logout" class="hidden text-left px-3 py-2 text-sm text-red-400 hover:bg-white/10 rounded-lg">Sign Out</button>
          </div>
        </nav>
      </div>
    </header>
  </Fragment>

  <!-- Page content -->
  <slot />

  <!-- Footer -->
  <Fragment slot="footer">
    <footer class="border-t border-sage-200/50 dark:border-earth-700 bg-earth-50 dark:bg-earth-950 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
        <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
          <!-- Brand -->
          <div>
            <span class="font-serif text-lg font-bold text-earth-800 dark:text-earth-100">Verscienta Health</span>
            <p class="mt-2 text-sm text-gray-600 dark:text-earth-400">
              Bridging traditional wisdom and modern science for holistic health.
            </p>
          </div>

          <!-- Explore -->
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-earth-100 uppercase tracking-wide mb-3">Explore</h3>
            <ul class="space-y-2">
              <li><a href="/herbs" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Herbs</a></li>
              <li><a href="/formulas" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Formulas</a></li>
              <li><a href="/conditions" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Conditions</a></li>
              <li><a href="/modalities" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Modalities</a></li>
            </ul>
          </div>

          <!-- Tools -->
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-earth-100 uppercase tracking-wide mb-3">Tools</h3>
            <ul class="space-y-2">
              <li><a href="/symptom-checker" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Symptom Checker</a></li>
              <li><a href="/tools/herb-drug-interactions" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Drug Interaction Checker</a></li>
              <li><a href="/search" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Search</a></li>
            </ul>
          </div>

          <!-- Legal -->
          <div>
            <h3 class="text-sm font-semibold text-gray-900 dark:text-earth-100 uppercase tracking-wide mb-3">Legal</h3>
            <ul class="space-y-2">
              <li><a href="/about" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">About</a></li>
              <li><a href="/privacy" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Privacy Policy</a></li>
              <li><a href="/terms" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Terms of Service</a></li>
              <li><a href="/contact" class="text-sm text-gray-600 dark:text-earth-400 hover:text-earth-600 dark:hover:text-earth-200 transition">Contact</a></li>
            </ul>
          </div>
        </div>

        <!-- Disclaimer -->
        <div class="mt-8 pt-8 border-t border-sage-200/50 dark:border-earth-700">
          <p class="text-xs text-gray-500 dark:text-earth-500 text-center">
            The information on this site is for educational purposes only and is not intended to replace professional medical advice.
            Always consult a qualified healthcare provider before starting any herbal supplement or treatment.
          </p>
          <p class="text-xs text-gray-400 dark:text-earth-600 text-center mt-2">
            &copy; {new Date().getFullYear()} Verscienta Health. All rights reserved.
          </p>
        </div>
      </div>
    </footer>
  </Fragment>
</RootLayout>

<script>
  // Mobile menu toggle
  document.getElementById('mobile-nav-toggle')?.addEventListener('click', () => {
    document.getElementById('mobile-nav')?.classList.toggle('hidden');
  });

  // Auth state: check if user is logged in and update nav
  (async function checkAuth() {
    try {
      const res = await fetch('/api/auth/me');
      const data = await res.json();

      if (data.user) {
        const name = data.user.first_name || data.user.email?.split('@')[0] || 'Account';

        // Desktop nav
        document.getElementById('nav-login')?.classList.add('hidden');
        const userMenu = document.getElementById('nav-user-menu');
        if (userMenu) {
          userMenu.classList.remove('hidden');
          const nameEl = document.getElementById('nav-user-name');
          if (nameEl) nameEl.textContent = name;
        }

        // Mobile nav
        document.getElementById('mobile-nav-login')?.classList.add('hidden');
        document.getElementById('mobile-nav-dashboard')?.classList.remove('hidden');
        document.getElementById('mobile-nav-profile')?.classList.remove('hidden');
        document.getElementById('mobile-nav-logout')?.classList.remove('hidden');
      }
    } catch {
      // Not logged in — keep defaults
    }
  })();

  // Desktop user dropdown toggle
  document.getElementById('nav-user-btn')?.addEventListener('click', () => {
    document.getElementById('nav-user-dropdown')?.classList.toggle('hidden');
  });

  // Close dropdown when clicking outside
  document.addEventListener('click', (e) => {
    const menu = document.getElementById('nav-user-menu');
    if (menu && !menu.contains(e.target as Node)) {
      document.getElementById('nav-user-dropdown')?.classList.add('hidden');
    }
  });

  // Logout handlers
  async function handleLogout() {
    try {
      await fetch('/api/auth/logout', { method: 'POST' });
    } catch {}
    window.location.href = '/login';
  }

  document.getElementById('nav-logout-btn')?.addEventListener('click', handleLogout);
  document.getElementById('mobile-nav-logout')?.addEventListener('click', handleLogout);
</script>
