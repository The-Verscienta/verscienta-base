{
  "name": "verscienta-astro",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "build": "npm run tokens:build && astro build",
    "preview": "astro preview",
    "check": "astro check",
    "tokens:build": "style-dictionary build --config style-dictionary.config.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lint": "eslint src/",
    "typecheck": "astro check && tsc --noEmit"
  },
  "dependencies": {
    "astro": "^5.0.0",
    "@astrojs/react": "^4.0.0",
    "@astrojs/cloudflare": "^12.0.0",
    "@directus/sdk": "^18.0.0",
    "@meilisearch/instant-meilisearch": "^0.21.0",
    "meilisearch": "^0.44.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-instantsearch": "^7.0.0",
    "zod": "^3.24.1",
    "katex": "^0.16.21",
    "@radix-ui/react-dialog": "^1.0.0",
    "@radix-ui/react-dropdown-menu": "^2.0.0",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-toast": "^1.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "typescript": "^5.7.0",
    "tailwindcss": "^4.1.0",
    "@tailwindcss/postcss": "^4.1.0",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/forms": "^0.5.10",
    "postcss": "^8.4.49",
    "style-dictionary": "^4.4.0",
    "vitest": "^3.0.0",
    "@playwright/test": "^1.49.0",
    "eslint": "^9.0.0"
  }
}
