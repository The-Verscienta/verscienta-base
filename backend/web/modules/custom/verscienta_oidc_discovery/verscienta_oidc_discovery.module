<?php

/**
 * @file
 * Hooks for the Verscienta OIDC Discovery module.
 */

/**
 * Implements hook_simple_oauth_oidc_claims_alter().
 *
 * Adds Drupal roles to the OIDC claims so client apps can read them
 * from the userinfo endpoint.
 */
function verscienta_oidc_discovery_simple_oauth_oidc_claims_alter(array &$claim_values, array $context): void {
  /** @var \Drupal\user\UserInterface $account */
  $account = $context['account'] ?? NULL;
  if ($account) {
    $claim_values['roles'] = $account->getRoles(TRUE);
  }
}
