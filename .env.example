# Drupal Backend Configuration
DRUPAL_BASE_URL=http://localhost:8080
DRUPAL_CLIENT_ID=your-oauth-client-id
DRUPAL_CLIENT_SECRET=your-oauth-client-secret

# Database
DRUPAL_DATABASE_NAME=verscienta_drupal
DRUPAL_DATABASE_USER=drupal_user
DRUPAL_DATABASE_PASSWORD=your-secure-password-here
MYSQL_ROOT_PASSWORD=your-root-password-here

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# xAI (Grok) API Configuration
XAI_API_KEY=your-xai-api-key-here

# Next.js Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_DRUPAL_BASE_URL=http://localhost:8080

# NextAuth Configuration
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-a-random-secret-key-here

# Cloudflare Turnstile
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# SymPy Compute Service
SYMPY_SERVICE_URL=http://sympy-compute:8000
SYMPY_API_KEY=your-internal-api-key-here
SYMPY_LOG_LEVEL=info

# CSRF Protection
CSRF_SECRET=your-csrf-secret-here

# Environment
NODE_ENV=development